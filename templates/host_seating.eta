<% layout("_layout", it) %>

<%
  function tt(k, fb){
    try{
      if (it && typeof it.t==='function'){
        const s = it.t(k);
        if(!s || s===k || s===`(${k})`) return fb;
        return s;
      }
    }catch(e){}
    return fb;
  }

  const restaurant = it.restaurant || {};
  const reservations = it.reservations || [];
  const sections = it.sections || [];
  const statuses = it.statuses || [];

  const totalReservations = reservations.length;
  const totalGuests = reservations.reduce(function(sum, r){ return sum + Number(r && r.people ? r.people : 0); }, 0);
  const newReservationsCount = reservations.filter(function(r){ return String((r && r.status) || 'new').toLowerCase() === 'new'; }).length;
  const roomsCount = Array.from(new Set(reservations.map(function(r){ return String((r && r.roomLabel) || '').trim(); }).filter(Boolean))).length;
  const tablesFlat = [];
  (sections || []).forEach(function(sec){ (sec && sec.tables ? sec.tables : []).forEach(function(t){ tablesFlat.push(t); }); });
  const totalTables = tablesFlat.length;
  const occupiedTables = statuses.filter(function(s){ const st = String((s && s.status) || '').toLowerCase(); return st === 'occupied' || st === 'open'; }).length;
  const reservedTables = statuses.filter(function(s){ return String((s && s.status) || '').toLowerCase() === 'reserved'; }).length;
  const dirtyTables = statuses.filter(function(s){ return String((s && s.status) || '').toLowerCase() === 'dirty'; }).length;
  const emptyTables = Math.max(totalTables - occupiedTables - reservedTables - dirtyTables, 0);
  const nextReservation = reservations.slice().sort(function(a,b){ return String((a && a.time) || '').localeCompare(String((b && b.time) || '')); })[0] || null;

  // Small safe mapping: tableId -> tableNumber (no guest data)
  const __tableIdToNumber = {};
  (sections || []).forEach(function(sec){
    (sec && sec.tables ? sec.tables : []).forEach(function(t){
      if (!t || !t.id) return;
      const num = Number(
        t.tableNumber != null ? t.tableNumber :
        (t.number != null ? t.number :
         (t.table_number != null ? t.table_number :
          (t.tableNo != null ? t.tableNo :
           (t.tableNum != null ? t.tableNum : 0))))
      );
      if (Number.isFinite(num) && num > 0) __tableIdToNumber[String(t.id)] = num;
    });
  });
  const __tableIdToStatusEntry = {};
  const __tableNumberToStatusEntry = {};
  (statuses || []).forEach(function(s){
    const safeEntry = {
      tableId: String((s && s.tableId) || ''),
      tableNumber: Number((s && s.tableNumber) || 0) || 0,
      status: String((s && s.status) || 'empty'),
      guestName: String((s && s.guestName) || ''),
      guestCount: (s && s.guestCount != null) ? Number(s.guestCount) : '',
      reservationTime: String((s && s.reservationTime) || ''),
      itemsCount: (s && s.itemsCount != null) ? Number(s.itemsCount) : '',
      subtotal: (s && s.subtotal != null) ? String(s.subtotal) : '',
    };
    if (safeEntry.tableId) __tableIdToStatusEntry[safeEntry.tableId] = safeEntry;
    if (safeEntry.tableNumber > 0) __tableNumberToStatusEntry[String(safeEntry.tableNumber)] = safeEntry;
  });
%>

<main class="host host-ops container" data-system-now-time="<%= it.systemNowTime || '' %>">
  <section class="host-shell">
    <div class="host-hero panel card">
      <div class="host-hero__content">
        <div class="host-badge">Host command center</div>
        <h1><%= tt('host.title', 'Host Screen') %> — <%= restaurant.name %></h1>
        <p class="muted"><%= restaurant.city %> • <%= restaurant.address %></p>
      </div>
      <div class="host-hero__meta">
        <div class="host-hero-chip">
          <span class="host-hero-chip__label">Reservations</span>
          <strong><%= totalReservations %></strong>
        </div>
        <div class="host-hero-chip">
          <span class="host-hero-chip__label">Guests tonight</span>
          <strong><%= totalGuests %></strong>
        </div>
        <div class="host-hero-chip">
          <span class="host-hero-chip__label">Rooms in use</span>
          <strong><%= roomsCount %></strong>
        </div>
      </div>
    </div>

    <aside class="host-time-card" id="host-time-card">
      <div class="host-time-card__eyebrow">Restaurant clock</div>
      <div class="host-time-card__clock" id="host-system-time-preview"><%= it.systemNowTime || '' %></div>
      <div class="host-time-card__date"><%= it.systemNowDate || '' %></div>
      <div class="host-time-card__inputs">
        <input id="host-system-date" type="date" value="<%= it.systemNowDate || '' %>" aria-label="Restaurant date">
        <input id="host-system-time" type="time" value="<%= it.systemNowTime || '' %>" aria-label="Restaurant time">
      </div>
      <div class="host-time-card__actions">
        <button id="host-system-apply-btn" type="button" class="btn primary sm">Apply preview</button>
        <button id="host-system-now-btn" type="button" class="btn ghost sm">Use real time</button>
      </div>
      <p class="host-time-card__status muted small" id="host-system-time-status"><%= tt('host.system_time.help', 'Use preview time to rehearse service flow or switch back to the real clock.') %></p>
    </aside>
  </section>

  <section class="host-kpi-grid" aria-label="Service overview">
    <article class="host-kpi-card card">
      <span class="host-kpi-card__label">New arrivals</span>
      <strong><%= newReservationsCount %></strong>
      <span class="host-kpi-card__hint">Fresh reservations still waiting</span>
    </article>
    <article class="host-kpi-card card">
      <span class="host-kpi-card__label">Next seating</span>
      <strong><%= nextReservation ? (nextReservation.time || '—') : '—' %></strong>
      <span class="host-kpi-card__hint"><%= nextReservation ? (nextReservation.name || 'Walk-in') : 'No upcoming reservations' %></span>
    </article>
    <article class="host-kpi-card card">
      <span class="host-kpi-card__label">Occupied tables</span>
      <strong><%= occupiedTables %>/<%= totalTables %></strong>
      <span class="host-kpi-card__hint"><%= emptyTables %> tables still available</span>
    </article>
    <article class="host-kpi-card card">
      <span class="host-kpi-card__label">Service coverage</span>
      <strong><%= totalTables ? Math.round((occupiedTables / totalTables) * 100) : 0 %>%</strong>
      <span class="host-kpi-card__hint">Live dining room utilization</span>
    </article>
  </section>

  <section class="host-grid">
    <div class="panel card host-reservations-panel">
      <div class="host-panel-head">
        <div>
          <h2><%= tt('host.reservations_today', "Today's Reservations") %></h2>
          <p class="muted small">Queue the right guest fast, then send them to the right table with fewer taps.</p>
        </div>
        <div class="host-head-pill"><%= totalReservations %> total</div>
      </div>

      <% if (reservations.length) { %>
        <div class="host-filter-row">
          <div class="host-filter-chips" role="tablist" aria-label="Reservation filters">
            <button type="button" class="host-filter-chip is-active" data-host-filter="all">All</button>
            <button type="button" class="host-filter-chip" data-host-filter="new">New</button>
            <button type="button" class="host-filter-chip" data-host-filter="soon">Soon</button>
            <button type="button" class="host-filter-chip" data-host-filter="large">Large party</button>
            <button type="button" class="host-filter-chip" data-host-filter="room">Assigned room</button>
          </div>

          <div class="host-resv-toolbar">
            <label class="host-search">
              <span class="host-search__icon">🔎</span>
              <input id="host-resv-search" type="search" placeholder="<%= tt('host.search_placeholder', 'Search by guest name…') %>" aria-label="<%= tt('host.search_label', 'Search reservations by guest name') %>">
            </label>
            <label class="host-sort">
              <span class="host-sort__label"><%= tt('host.sort_label', 'Sort by') %></span>
              <select id="host-resv-sort" aria-label="<%= tt('host.sort_label', 'Sort by') %>">
                <option value="new_first"><%= tt('host.sort_new_first', 'New first') %></option>
                <option value="time_asc"><%= tt('host.sort_time', 'Time') %></option>
                <option value="name_asc"><%= tt('host.sort_name', 'Guest name') %></option>
                <option value="room_asc"><%= tt('host.sort_room', 'Room') %></option>
                <option value="party_desc"><%= tt('host.sort_party', 'Party size') %></option>
              </select>
            </label>
          </div>
        </div>
        <div class="host-resv-summary" id="host-resv-summary"><%= reservations.length %> <%= tt('host.summary_suffix', 'reservations') %></div>
        <ul class="list" id="resv-list">
          <% reservations.forEach(function(r){ %>
            <li class="item reservation-card" data-res-id="<%= r.id %>" data-name="<%= String(r.name || "").toLowerCase() %>" data-room="<%= String(r.roomLabel || "").toLowerCase() %>" data-time="<%= r.time || "" %>" data-people="<%= Number(r.people || 0) %>" data-status="<%= r.status || "new" %>" data-created-at="<%= Number(r.createdAt || 0) %>">
              <label class="radio reservation-card__label">
                <input type="radio" name="resv" value="<%= r.id %>">
                <div class="radio-body reservation-card__body">
                  <div class="reservation-card__top">
                    <div class="reservation-card__top-main">
                      <div class="reservation-card__guest resv-name"><%= r.name || '—' %></div>
                      <% if ((r.status || 'new') === 'new') { %><span class="reservation-badge-new"><%= tt('host.badge_new', 'New') %></span><% } %>
                    </div>
                    <div class="reservation-card__time"><%= r.time %></div>
                  </div>
                  <div class="reservation-card__meta">
                    <span class="reservation-pill reservation-pill--guests">
                      <strong><%= r.people %></strong>
                      <span><%= tt('host.people_unit', 'Guests') %></span>
                    </span>
                    <% if (r.roomLabel) { %>
                      <span class="reservation-pill reservation-pill--room">
                        <span class="reservation-pill__label"><%= tt('host.room_label_short', 'Room') %></span>
                        <strong><%= r.roomLabel %></strong>
                      </span>
                    <% } else { %>
                      <span class="reservation-pill reservation-pill--room is-muted">
                        <span class="reservation-pill__label"><%= tt('host.room_label_short', 'Room') %></span>
                        <strong>—</strong>
                      </span>
                    <% } %>
                    <span class="reservation-pill reservation-pill--service <%= (r.status || 'new') === 'new' ? 'is-live' : '' %>">
                      <span class="reservation-pill__label">Service</span>
                      <strong><%= (r.status || 'new') === 'new' ? tt('host.badge_ready', 'Ready to seat') : String(r.status || 'Pending') %></strong>
                    </span>
                  </div>
                  <div class="reservation-card__footer">
                    <span class="reservation-card__footnote"><%= r.roomLabel ? 'Preferred area is already assigned.' : 'Choose the best room after selecting a table.' %></span>
                    <span class="reservation-card__signal <%= Number(r.people || 0) >= 6 ? 'is-strong' : '' %>">
                      <i></i>
                      <%= Number(r.people || 0) >= 6 ? 'Large party' : 'Standard flow' %>
                    </span>
                  </div>
                </div>
              </label>
              <div class="resv-actions reservation-card__actions">
                <button type="button" class="link-btn resv-cancel" data-action="cancel" data-id="<%= r.id %>">
                  <%= tt('host.btn_cancel', 'Cancel') %>
                </button>
                <button type="button" class="link-btn resv-noshow" data-action="no_show" data-id="<%= r.id %>">
                  <%= tt('host.btn_no_show', 'No Show') %>
                </button>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted"><%= tt('host.no_reservations', 'No reservations for today at this restaurant.') %></p>
      <% } %>
    </div>

    <div class="panel card host-map-panel">
      <div class="host-map-head">
        <div>
          <h2><%= tt('host.floor_map_title', 'Restaurant Map (Live)') %></h2>
          <p class="muted small"><%= tt('host.floor_map_help', 'Select a reservation, choose a table or multiple tables (merge), then click the seat button.') %></p>
        </div>
        <div class="host-map-flow" aria-label="Seating steps">
          <span>1. Pick guest</span>
          <span>2. Select table</span>
          <span>3. Confirm seating</span>
        </div>
      </div>

      <div class="host-ops-strip">
        <div class="host-selection-card" id="host-selection-card">
          <div class="host-selection-card__eyebrow">Current mission</div>
          <div class="host-selection-card__name" id="host-selected-res-name">No reservation selected</div>
          <div class="host-selection-card__meta" id="host-selected-res-meta">Choose a reservation from the queue to unlock seating actions.</div>
          <div class="host-selection-card__targets">
            <span class="host-target-pill" id="host-selected-target">No table selected</span>
            <span class="host-target-pill is-soft" id="host-selected-state">Waiting for selection</span>
          </div>
          <div class="host-selection-card__stats">
            <div class="host-selection-stat">
              <span class="host-selection-stat__label">Reservation</span>
              <strong id="host-selected-res-short">—</strong>
            </div>
            <div class="host-selection-stat">
              <span class="host-selection-stat__label">Target</span>
              <strong id="host-selected-target-short">—</strong>
            </div>
            <div class="host-selection-stat">
              <span class="host-selection-stat__label">Table status</span>
              <strong id="host-selected-table-status">Waiting</strong>
            </div>
          </div>
        </div>

        <div class="host-map-legend" aria-label="Dining room legend">
          <span class="host-legend-pill"><i class="host-legend-dot is-empty"></i> Empty</span>
          <span class="host-legend-pill"><i class="host-legend-dot is-occupied"></i> Occupied</span>
          <span class="host-legend-pill"><i class="host-legend-dot is-reserved"></i> Reserved</span>
          <span class="host-legend-pill"><i class="host-legend-dot is-dirty"></i> Dirty</span>
        </div>
      </div>

      <div
        id="sb-floor-root"
        class="floor-wrapper"
        data-rid="<%= it.rid %>"
        data-click-mode="host"
        data-right-panel="outside"
      ></div>

      <div class="host-actions host-actions--premium">
        <div class="host-actions__main">
          <button id="seat-btn" type="button" class="btn primary sm">
            <%= tt('host.btn_seat', 'Seat at Selected Table(s)') %>
          </button>
        </div>
        <div class="host-status-cluster">
          <div class="host-status-cluster__label">Quick table status</div>
          <div class="host-mini-actions host-mini-actions--status-grid">
            <button id="mark-occupied-btn" type="button" class="btn ghost sm host-status-btn is-occupied">Occupied</button>
            <button id="mark-reserved-btn" type="button" class="btn ghost sm host-status-btn is-reserved"><%= tt('host.btn_mark_reserved', 'Mark Reserved') %></button>
            <button id="mark-dirty-btn" type="button" class="btn ghost sm host-status-btn is-dirty">Dirty</button>
            <button id="mark-empty-btn" type="button" class="btn ghost sm host-status-btn is-empty"><%= tt('host.btn_mark_empty', 'Mark Empty') %></button>
          </div>
        </div>
        <p class="muted small" id="host-selection-helper"><%= tt('host.merge_hint', 'You can select multiple tables for the same reservation (table merge).') %></p>
      </div>
    </div>
  </section>
</main>

<!-- כרטיסיית צד לפרטי שולחן תפוס -->
<div id="table-info-backdrop" class="table-info-backdrop"></div>
<aside id="table-info-panel" class="table-info-panel" aria-hidden="true">
  <div class="table-info-inner">
    <header class="table-info-header">
      <div>
        <div class="tip-label"><%= tt('host.table_details', 'Table Details') %></div>
        <div class="tip-title"><%= tt('host.table_label', 'Table') %> <span id="tip-table-number">—</span></div>
      </div>
      <button type="button" class="tip-close-btn" id="tip-close-btn" aria-label="<%= tt('host.close_table_details', 'Close table details') %>">
        ✕
      </button>
    </header>

    <section class="table-info-hero" id="table-info-hero" data-status="unknown">
      <div class="table-info-hero__row">
        <span id="tip-status" class="tip-status-badge">—</span>
        <span class="table-info-hero__copy" id="tip-status-copy"><%= tt('host.table_info_note', 'Information is taken from the last reservation assigned to this table.') %></span>
      </div>
      <div class="table-info-hero__table"><%= tt('host.table_label', 'Table') %> <span id="tip-table-number-hero">—</span></div>
      <p class="table-info-hero__subtitle" id="tip-summary-line"><%= tt('host.table_info_note', 'Information is taken from the last reservation assigned to this table.') %></p>
    </section>

    <section class="table-info-grid" aria-label="Table details summary">
      <article class="table-info-card">
        <span class="table-info-card__label"><%= tt('host.guest_name', 'Guest Name') %></span>
        <strong class="table-info-card__value" id="tip-guest-name">—</strong>
      </article>
      <article class="table-info-card">
        <span class="table-info-card__label"><%= tt('host.num_guests', 'Number of Guests') %></span>
        <strong class="table-info-card__value" id="tip-people">—</strong>
      </article>
      <article class="table-info-card">
        <span class="table-info-card__label"><%= tt('host.reservation_time', 'Reservation Time') %></span>
        <strong class="table-info-card__value" id="tip-time">—</strong>
      </article>
      <article class="table-info-card">
        <span class="table-info-card__label"><%= tt('host.table_status_label', 'Table Status') %></span>
        <strong class="table-info-card__value" id="tip-status-text">—</strong>
      </article>
    </section>

    <section class="table-info-body">
      <div class="tip-row tip-row--stacked">
        <span class="tip-row-label"><%= tt('host.table_details', 'Table Details') %></span>
        <span class="tip-row-note" id="tip-guidance"><%= tt('host.table_info_note', 'Information is taken from the last reservation assigned to this table.') %></span>
      </div>
    </section>

    <footer class="table-info-footer">
      <p class="muted small">
        <%= tt('host.table_info_note', 'Information is taken from the last reservation assigned to this table.') %>
      </p>
    </footer>
  </div>
</aside>

<style>
  .host-header{ display:flex; align-items:flex-start; justify-content:space-between; gap:18px; flex-wrap:wrap; }
  .host-time-card{ min-width:320px; max-width:420px; padding:14px 16px; border-radius:18px; border:1px solid rgba(148,163,184,.18); background:linear-gradient(180deg, rgba(15,23,42,.96), rgba(15,23,42,.82)); box-shadow:0 18px 46px rgba(2,6,23,.28); }
  .host-time-card__eyebrow{ font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:#93c5fd; font-weight:800; }
  .host-time-card__clock{ margin-top:6px; font-size:20px; font-weight:800; color:#f8fafc; }
  .host-time-card__inputs{ display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
  .host-time-card__inputs input{ width:100%; min-height:40px; border-radius:12px; border:1px solid rgba(148,163,184,.18); background:#0b1327; color:#e5eefb; padding:0 10px; }
  .host-time-card__actions{ display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
  .host-time-card__status, #host-system-time-status{ margin-top:8px; }
  .host-resv-toolbar{ display:flex; align-items:center; justify-content:space-between; gap:12px; margin:12px 0 10px; flex-wrap:wrap; }
  .host-search{ flex:1 1 240px; display:flex; align-items:center; gap:8px; min-height:42px; border-radius:14px; border:1px solid rgba(148,163,184,.18); background:rgba(15,23,42,.72); padding:0 12px; }
  .host-search input{ flex:1 1 auto; min-width:0; border:0; outline:0; background:transparent; color:#e5eefb; }
  .host-search__icon{ opacity:.72; }
  .host-sort{ display:flex; align-items:center; gap:8px; }
  .host-sort__label{ font-size:12px; color:#94a3b8; font-weight:700; }
  .host-sort select{ min-height:42px; border-radius:12px; border:1px solid rgba(148,163,184,.18); background:#0b1327; color:#e5eefb; padding:0 12px; }
  .host-resv-summary{ color:#94a3b8; font-size:12px; margin-bottom:8px; }
  .reservation-card{ position:relative; display:grid; grid-template-columns:minmax(0,1fr) auto; gap:14px; align-items:center; padding:14px 0; }
  .reservation-card::before{ content:""; position:absolute; inset:12px auto 12px 12px; width:4px; border-radius:999px; background:linear-gradient(180deg, rgba(59,130,246,.92), rgba(96,165,250,.22)); box-shadow:0 0 0 1px rgba(147,197,253,.14); opacity:.88; }
  .reservation-card__label{ display:block; width:100%; cursor:pointer; }
  .reservation-card__body{ display:flex; flex-direction:column; gap:12px; padding-inline-start:8px; }
  .reservation-card__top{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
  .reservation-card__top-main{ display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .reservation-card__guest{ font-size:16px; font-weight:800; color:#f8fafc; }
  .reservation-card__time{ font-size:14px; font-weight:800; color:#93c5fd; padding:4px 10px; border-radius:999px; background:rgba(59,130,246,.14); border:1px solid rgba(59,130,246,.24); }
  .reservation-card__meta{ display:flex; gap:8px; flex-wrap:wrap; }
  .reservation-pill{ display:inline-flex; align-items:center; gap:7px; padding:8px 11px; border-radius:14px; border:1px solid rgba(148,163,184,.16); background:rgba(15,23,42,.76); color:#e5eefb; box-shadow:inset 0 1px 0 rgba(255,255,255,.03); }
  .reservation-pill strong{ font-size:13px; }
  .reservation-pill__label{ font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:#94a3b8; font-weight:800; }
  .reservation-pill--room{ background:rgba(59,130,246,.12); border-color:rgba(59,130,246,.24); }
  .reservation-pill--guests{ background:rgba(148,163,184,.08); }
  .reservation-pill--service{ background:rgba(14,116,144,.12); border-color:rgba(34,211,238,.2); }
  .reservation-pill--service.is-live{ background:rgba(37,99,235,.18); border-color:rgba(96,165,250,.26); }
  .reservation-pill.is-muted{ opacity:.78; }
  .reservation-card__footer{ display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
  .reservation-card__footnote{ font-size:12px; color:#94a3b8; }
  .reservation-card__signal{ display:inline-flex; align-items:center; gap:8px; font-size:11px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:#bfdbfe; }
  .reservation-card__signal i{ width:8px; height:8px; border-radius:999px; background:#60a5fa; box-shadow:0 0 0 5px rgba(59,130,246,.14); }
  .reservation-card__signal.is-strong i{ background:#f59e0b; box-shadow:0 0 0 5px rgba(245,158,11,.14); }
  .reservation-card__actions{ display:flex; flex-direction:column; align-items:flex-end; gap:8px; }
  .reservation-card__actions .link-btn{ min-width:108px; text-align:center; padding:10px 12px; border-radius:12px; border:1px solid rgba(148,163,184,.14); background:rgba(15,23,42,.66); color:#dbeafe; font-weight:700; box-shadow:0 10px 24px rgba(2,6,23,.18); }
  .reservation-card__actions .link-btn:hover{ border-color:rgba(96,165,250,.28); background:rgba(30,41,59,.88); }
  .room-badge { display:inline-block; padding:1px 7px; border-radius:6px; font-size:11px; font-weight:700; background: rgba(59,130,246,.15); color: #93c5fd; border: 1px solid rgba(59,130,246,.25); margin-inline-start: 4px; vertical-align: middle; }
  .reservation-badge-new{ display:inline-flex; align-items:center; padding:4px 8px; border-radius:999px; font-size:10px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:#fef3c7; background:rgba(245,158,11,.16); border:1px solid rgba(245,158,11,.30); }
  .reservation-card.is-hidden{ display:none !important; }
  @media (max-width: 900px){ .host-header{ flex-direction:column; } .host-time-card{ width:100%; max-width:none; } }
  @media (max-width: 640px){ .reservation-card{ grid-template-columns:1fr; } .reservation-card::before{ inset:12px auto auto 12px; width:42px; height:4px; } .reservation-card__actions{ align-items:stretch; } .reservation-card__actions .link-btn{ width:100%; } .reservation-card__top{ align-items:flex-start; flex-direction:column; } .reservation-card__footer{ align-items:flex-start; } .host-time-card__inputs{ grid-template-columns:1fr; } .host-resv-toolbar{ flex-direction:column; align-items:stretch; } .host-sort{ width:100%; justify-content:space-between; } .host-sort select{ flex:1 1 auto; } }


  /* Keep the classic host-side table details panel instead of the embedded drawer */
  .host-map-panel #sb-floor-root .sbv-right,
  .host-map-panel #sb-floor-root .sbv-mobile-backdrop{
    display:none !important;
  }

</style>
<!-- Same floor-view assets as the waiter lobby -->

<link rel="stylesheet" href="/dist/floor-index.css">
<link rel="stylesheet" href="/dist/floor-floor-view-app.css">
<link rel="stylesheet" href="/public/css/sb-map-frame-overrides.css">
<script type="module" src="/dist/floor-view-app.js"></script>

<script>
(function(){
  const rid = "<%= it.rid %>";
  const state = {
    selectedResId: null,
    selectedTables: new Set(),   // מספרי שולחנות שנבחרו
    selectedTableIds: new Set(), // IDs של שולחנות שנבחרו (לסטטוסים)
    selectedBar: null,
  };

  const resvList = document.getElementById("resv-list");
  const seatBtn = document.getElementById("seat-btn");
  const markOccupiedBtn = document.getElementById("mark-occupied-btn");
  const markReservedBtn = document.getElementById("mark-reserved-btn");
  const markDirtyBtn = document.getElementById("mark-dirty-btn");
  const markEmptyBtn = document.getElementById("mark-empty-btn");
  const systemDateInput = document.getElementById("host-system-date");
  const systemTimeInput = document.getElementById("host-system-time");
  const systemApplyBtn = document.getElementById("host-system-apply-btn");
  const systemNowBtn = document.getElementById("host-system-now-btn");
  const systemPreview = document.getElementById("host-system-time-preview");
  const systemStatus = document.getElementById("host-system-time-status");

  const hostResvSearch = document.getElementById("host-resv-search");
  const hostResvSort = document.getElementById("host-resv-sort");
  const hostResvSummary = document.getElementById("host-resv-summary");

  const hostRoot = document.querySelector('.host.host-ops');
  const hostFilterButtons = Array.from(document.querySelectorAll('[data-host-filter]'));
  const hostSelectedResName = document.getElementById('host-selected-res-name');
  const hostSelectedResMeta = document.getElementById('host-selected-res-meta');
  const hostSelectedTarget = document.getElementById('host-selected-target');
  const hostSelectedState = document.getElementById('host-selected-state');
  const hostSelectionHelper = document.getElementById('host-selection-helper');
  const hostSelectedResShort = document.getElementById('host-selected-res-short');
  const hostSelectedTargetShort = document.getElementById('host-selected-target-short');
  const hostSelectedTableStatus = document.getElementById('host-selected-table-status');
  const seatBtnDefaultLabel = "<%= tt('host.btn_seat', 'Seat at Selected Table(s)') %>";
  const seatBtnReadyLabel = "<%= tt('host.btn_seat_ready', 'Seat reservation') %>";
  const hostDefaultResName = 'No reservation selected';
  const hostDefaultResMeta = 'Choose a reservation from the queue to unlock seating actions.';
  const hostDefaultTarget = 'No table selected';
  const hostDefaultState = 'Waiting for selection';
  const __HOST_NOW_TIME = ((hostRoot && hostRoot.dataset && hostRoot.dataset.systemNowTime) || '').slice(0,5);
  let activeReservationFilter = 'all';


  function minutesFromHHMM(value) {
    const m = String(value || '').match(/^(\d{1,2}):(\d{2})/);
    if (!m) return null;
    return Number(m[1]) * 60 + Number(m[2]);
  }

  function matchesReservationFilter(li) {
    if (!li) return false;
    if (activeReservationFilter === 'all') return true;
    const status = String(li.dataset.status || 'new').toLowerCase();
    const people = Number(li.dataset.people || 0);
    const room = String(li.dataset.room || '').trim();
    const itemMinutes = minutesFromHHMM(li.dataset.time || '');
    const nowMinutes = minutesFromHHMM(__HOST_NOW_TIME);

    if (activeReservationFilter === 'new') return status === 'new';
    if (activeReservationFilter === 'large') return people >= 6;
    if (activeReservationFilter === 'room') return !!room;
    if (activeReservationFilter === 'soon') {
      if (itemMinutes == null) return false;
      if (nowMinutes == null) return true;
      const delta = itemMinutes - nowMinutes;
      return delta >= 0 && delta <= 90;
    }
    return true;
  }

  function updateFilterButtonsUI() {
    hostFilterButtons.forEach(function(btn){
      const isActive = String(btn.dataset.hostFilter || 'all') === activeReservationFilter;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
  }

  function getSelectedReservationItem() {
    if (!resvList || !state.selectedResId) return null;
    return resvList.querySelector('li[data-res-id="' + state.selectedResId + '"]');
  }

  function updateReservationSelectionStyles() {
    if (!resvList) return;
    Array.from(resvList.querySelectorAll('li[data-res-id]')).forEach(function(li){
      li.classList.toggle('is-active', !!state.selectedResId && li.getAttribute('data-res-id') === String(state.selectedResId));
    });
  }

  function getEffectiveSelectedTableNumbers() {
    const direct = Array.from(state.selectedTables || []).map(Number).filter(function(n){ return Number.isFinite(n) && n > 0; });
    if (direct.length) return Array.from(new Set(direct)).sort(function(a,b){ return a-b; });
    const derived = Array.from(state.selectedTableIds || []).map(function(id){ return __SB_TABLE_ID_TO_NUMBER[String(id)]; }).map(Number).filter(function(n){ return Number.isFinite(n) && n > 0; });
    return Array.from(new Set(derived)).sort(function(a,b){ return a-b; });
  }

  function getEffectiveSelectedBar() {
    return (state.selectedBar && state.selectedBar.seatId)
      ? state.selectedBar
      : getSelectedBarFromDataset();
  }

  function updateSeatActionState() {
    const effectiveBar = getEffectiveSelectedBar();
    const selectedTables = getEffectiveSelectedTableNumbers();
    const hasTarget = !!(selectedTables.length || (effectiveBar && effectiveBar.seatId));
    const hasReservation = !!String(state.selectedResId || '').trim();
    const ready = hasReservation && hasTarget;

    if (seatBtn) {
      seatBtn.disabled = !ready;
      seatBtn.classList.toggle('is-disabled', !ready);
      if (effectiveBar && effectiveBar.seatId) {
        seatBtn.textContent = ready ? (seatBtnReadyLabel + ' · Bar') : seatBtnDefaultLabel;
      } else if (selectedTables.length === 1) {
        seatBtn.textContent = ready ? (seatBtnReadyLabel + ' · Table ' + selectedTables[0]) : seatBtnDefaultLabel;
      } else if (selectedTables.length > 1) {
        seatBtn.textContent = ready ? (seatBtnReadyLabel + ' · ' + selectedTables.length + ' tables') : seatBtnDefaultLabel;
      } else {
        seatBtn.textContent = seatBtnDefaultLabel;
      }
    }

    const enableStatusActions = !!(selectedTables.length || Array.from(state.selectedTableIds || []).length || (effectiveBar && effectiveBar.tableId));
    [markOccupiedBtn, markReservedBtn, markDirtyBtn, markEmptyBtn].forEach(function(btn){
      if (!btn) return;
      btn.disabled = !enableStatusActions;
      btn.classList.toggle('is-disabled', !enableStatusActions);
    });

    if (hostSelectionHelper) {
      if (!hasReservation && !hasTarget) hostSelectionHelper.textContent = 'Choose a reservation and then pick a table or bar seat.';
      else if (!hasReservation) hostSelectionHelper.textContent = 'Target selected. Now choose which reservation to seat.';
      else if (!hasTarget) hostSelectionHelper.textContent = 'Reservation selected. Pick one or more tables on the map.';
      else hostSelectionHelper.textContent = 'Ready to seat. Review the target and confirm.';
    }
  }

  function updateSelectionMission() {
    const selectedItem = getSelectedReservationItem();
    const effectiveBar = getEffectiveSelectedBar();
    const selectedTables = getEffectiveSelectedTableNumbers();
    const selectedStatusEntry = getSelectedStatusEntry();
    const selectedStatusLabel = mapStatusToLabel((selectedStatusEntry && selectedStatusEntry.status) || '');

    if (selectedItem) {
      const guestName = (selectedItem.querySelector('.resv-name') && selectedItem.querySelector('.resv-name').textContent || '').trim() || 'Guest';
      const parts = [];
      if (selectedItem.dataset.time) parts.push(selectedItem.dataset.time);
      if (selectedItem.dataset.people) parts.push(selectedItem.dataset.people + ' guests');
      if (selectedItem.dataset.room) parts.push('Room ' + selectedItem.dataset.room);
      if (hostSelectedResName) hostSelectedResName.textContent = guestName;
      if (hostSelectedResMeta) hostSelectedResMeta.textContent = parts.length ? parts.join(' · ') : hostDefaultResMeta;
      if (hostSelectedResShort) hostSelectedResShort.textContent = guestName;
      if (hostSelectedState) hostSelectedState.textContent = hasTargetText();
    } else {
      if (hostSelectedResName) hostSelectedResName.textContent = hostDefaultResName;
      if (hostSelectedResMeta) hostSelectedResMeta.textContent = hostDefaultResMeta;
      if (hostSelectedResShort) hostSelectedResShort.textContent = '—';
      if (hostSelectedState) hostSelectedState.textContent = hostDefaultState;
    }

    if (effectiveBar && effectiveBar.seatId) {
      const seatNo = Number(effectiveBar.seatNumber || 0);
      const cap = Number(effectiveBar.capacity || 0);
      const text = seatNo > 0 ? ('Bar seat ' + seatNo + (cap > 0 ? ' of ' + cap : '')) : 'Bar seating selected';
      if (hostSelectedTarget) hostSelectedTarget.textContent = text;
      if (hostSelectedTargetShort) hostSelectedTargetShort.textContent = seatNo > 0 ? ('Seat ' + seatNo) : 'Bar';
    } else if (selectedTables.length === 1) {
      if (hostSelectedTarget) hostSelectedTarget.textContent = 'Table ' + selectedTables[0];
      if (hostSelectedTargetShort) hostSelectedTargetShort.textContent = 'T' + selectedTables[0];
    } else if (selectedTables.length > 1) {
      if (hostSelectedTarget) hostSelectedTarget.textContent = selectedTables.length + ' tables · ' + selectedTables.join(', ');
      if (hostSelectedTargetShort) hostSelectedTargetShort.textContent = selectedTables.length + ' tables';
    } else {
      if (hostSelectedTarget) hostSelectedTarget.textContent = hostDefaultTarget;
      if (hostSelectedTargetShort) hostSelectedTargetShort.textContent = '—';
    }

    if (hostSelectedTableStatus) {
      hostSelectedTableStatus.textContent = selectedStatusEntry ? selectedStatusLabel : 'Waiting';
    }

    updateReservationSelectionStyles();
    updateSeatActionState();

    function hasTargetText() {
      if (selectedStatusEntry && selectedStatusEntry.status) return selectedStatusLabel;
      if (effectiveBar && effectiveBar.seatId) return 'Bar seat selected';
      if (selectedTables.length === 1) return 'Single table selected';
      if (selectedTables.length > 1) return 'Merge layout selected';
      return 'Choose seating target';
    }
  }

  function compareReservations(a, b, mode) {
    const nameA = (a.dataset.name || "");
    const nameB = (b.dataset.name || "");
    const roomA = (a.dataset.room || "");
    const roomB = (b.dataset.room || "");
    const timeA = (a.dataset.time || "");
    const timeB = (b.dataset.time || "");
    const peopleA = Number(a.dataset.people || 0);
    const peopleB = Number(b.dataset.people || 0);
    const createdA = Number(a.dataset.createdAt || 0);
    const createdB = Number(b.dataset.createdAt || 0);
    const statusA = (a.dataset.status || "new");
    const statusB = (b.dataset.status || "new");

    if (mode === "name_asc") return nameA.localeCompare(nameB) || timeA.localeCompare(timeB);
    if (mode === "room_asc") return roomA.localeCompare(roomB) || timeA.localeCompare(timeB) || nameA.localeCompare(nameB);
    if (mode === "party_desc") return (peopleB - peopleA) || timeA.localeCompare(timeB) || nameA.localeCompare(nameB);
    if (mode === "time_asc") return timeA.localeCompare(timeB) || nameA.localeCompare(nameB);

    const rankA = statusA === "new" ? 0 : 1;
    const rankB = statusB === "new" ? 0 : 1;
    return (rankA - rankB) || (createdB - createdA) || timeA.localeCompare(timeB) || nameA.localeCompare(nameB);
  }

  function applyReservationFilters() {
    if (!resvList) return;
    const term = ((hostResvSearch && hostResvSearch.value) || "").trim().toLowerCase();
    const mode = (hostResvSort && hostResvSort.value) || "new_first";
    const items = Array.from(resvList.querySelectorAll('li[data-res-id]'));
    const visible = [];

    items.forEach(function(li){
      const haystack = [li.dataset.name || "", li.dataset.room || "", li.dataset.time || ""].join(" ");
      const show = (!term || haystack.indexOf(term) >= 0) && matchesReservationFilter(li);
      li.classList.toggle("is-hidden", !show);
      if (show) visible.push(li);
    });

    visible.sort(function(a, b){ return compareReservations(a, b, mode); });
    visible.forEach(function(li){ resvList.appendChild(li); });

    if (hostResvSummary) {
      hostResvSummary.textContent = visible.length + " " + (visible.length === 1
        ? "<%= tt('host.summary_suffix_single', 'reservation') %>"
        : "<%= tt('host.summary_suffix', 'reservations') %>");
    }
    updateFilterButtonsUI();
  }

  if (hostResvSearch) hostResvSearch.addEventListener("input", applyReservationFilters);
  if (hostResvSort) hostResvSort.addEventListener("change", applyReservationFilters);
  hostFilterButtons.forEach(function(btn){
    btn.addEventListener('click', function(){
      activeReservationFilter = String(btn.dataset.hostFilter || 'all');
      applyReservationFilters();
      updateSelectionMission();
    });
  });

  // Selection updates from the embedded floor-view app
  const __SB_TABLE_ID_TO_NUMBER = <%= JSON.stringify(__tableIdToNumber) %>;
  const __SB_STATUS_BY_ID = <%= JSON.stringify(__tableIdToStatusEntry) %>;
  const __SB_STATUS_BY_NUMBER = <%= JSON.stringify(__tableNumberToStatusEntry) %>;
  let __hostTableInfoRequestId = 0;
  let __hostStatusesLoadedAt = 0;
  let __hostStatusesPromise = null;

  function getStatusEntryBySelection(tableId, tableNumber){
    const idKey = String(tableId || '').trim();
    if (idKey && __SB_STATUS_BY_ID[idKey]) return __SB_STATUS_BY_ID[idKey];
    const numKey = String(Number(tableNumber || 0) || 0);
    if (numKey !== '0' && __SB_STATUS_BY_NUMBER[numKey]) return __SB_STATUS_BY_NUMBER[numKey];
    return null;
  }

  function setStatusEntry(entry){
    if (!entry) return null;
    const safeEntry = {
      tableId: String((entry && entry.tableId) || ''),
      tableNumber: Number((entry && entry.tableNumber) || 0) || 0,
      status: normalizeHostTableStatus((entry && entry.status) || 'empty'),
      guestName: String((entry && entry.guestName) || ''),
      guestCount: (entry && entry.guestCount != null) ? Number(entry.guestCount) : '',
      reservationTime: String((entry && entry.reservationTime) || ''),
      itemsCount: (entry && entry.itemsCount != null) ? Number(entry.itemsCount) : '',
      subtotal: (entry && entry.subtotal != null) ? String(entry.subtotal) : '',
    };
    if (safeEntry.tableId) __SB_STATUS_BY_ID[safeEntry.tableId] = safeEntry;
    if (safeEntry.tableNumber > 0) __SB_STATUS_BY_NUMBER[String(safeEntry.tableNumber)] = safeEntry;
    return safeEntry;
  }

  function normalizeHostTableStatus(status){
    const s = String(status || '').toLowerCase();
    if (s === 'open') return 'occupied';
    if (s === 'free') return 'empty';
    if (s === 'needs_cleaning') return 'dirty';
    return s || 'empty';
  }

  async function ensureLiveHostStatuses(force){
    const now = Date.now();
    if (!force && __hostStatusesLoadedAt && (now - __hostStatusesLoadedAt) < 12000) return;
    if (__hostStatusesPromise) {
      await __hostStatusesPromise;
      return;
    }

    __hostStatusesPromise = (async function(){
      try {
        const res = await fetch('/api/floor-plans/' + encodeURIComponent(rid) + '/statuses', {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
        });
        const data = await res.json().catch(function(){ return []; });
        if (!res.ok || !Array.isArray(data)) throw new Error('status_refresh_failed');
        data.forEach(function(entry){ setStatusEntry(entry); });
        __hostStatusesLoadedAt = Date.now();
      } catch (e) {
        console.warn('[HOST] live status refresh failed', e);
      } finally {
        __hostStatusesPromise = null;
      }
    })();

    await __hostStatusesPromise;
  }

  function getSelectedStatusEntry(){
    const effectiveBar = getEffectiveSelectedBar();
    const selectedTables = getEffectiveSelectedTableNumbers();
    const tableId = effectiveBar && effectiveBar.tableId ? String(effectiveBar.tableId) : String(Array.from(state.selectedTableIds || [])[0] || '');
    const tableNumber = effectiveBar && effectiveBar.tableNumber ? Number(effectiveBar.tableNumber) : Number(selectedTables[0] || 0);
    return getStatusEntryBySelection(tableId, tableNumber);
  }

  async function syncTableInfoPanelFromSelection(detail){
    try {
      const root = document.getElementById('sb-floor-root');
      const ds = root && root.dataset ? root.dataset : {};
      const tableIds = detail && Array.isArray(detail.tableIds) ? detail.tableIds : [];
      const tableNumbers = detail && Array.isArray(detail.tableNumbers) ? detail.tableNumbers : [];
      const tableId = String(tableIds[0] || ds.selectedTableId || ds.selectedBarTableId || '').trim();
      const tableNumber = Number(tableNumbers[0] || ds.selectedTableNumber || ds.selectedBarTableNumber || 0) || 0;
      if (!tableId && !tableNumber) {
        closeTableInfoPanel();
        return;
      }

      const requestId = ++__hostTableInfoRequestId;
      let statusEntry = getStatusEntryBySelection(tableId, tableNumber);
      const detailStatus = normalizeHostTableStatus(
        (detail && (detail.status || (detail.statusEntry && detail.statusEntry.status))) ||
        (ds.selectedTableStatus || ds.selectedBarTableStatus || '')
      );
      const fallbackStatus = normalizeHostTableStatus((statusEntry && statusEntry.status) || detailStatus || 'empty');
      const baseInfo = {
        tableNumber: tableNumber || (statusEntry && statusEntry.tableNumber) || '—',
        name: (statusEntry && statusEntry.guestName) || '',
        people: (statusEntry && statusEntry.guestCount !== '') ? statusEntry.guestCount : '',
        time: (statusEntry && statusEntry.reservationTime) || '',
        status: fallbackStatus || 'empty',
      };

      if (detail && detail.isBarSeat) {
        const seatNumber = Number(detail.barSeatNumber || ds.selectedBarSeatNumber || 0) || 0;
        const seatCapacity = Number(detail.barSeatCapacity || ds.selectedBarSeatCapacity || 0) || 0;
        if (!baseInfo.name) baseInfo.name = seatNumber > 0 ? ('Bar seat ' + seatNumber) : 'Bar seating';
        if (!baseInfo.people && seatNumber > 0) baseInfo.people = seatCapacity > 0 ? (seatNumber + ' / ' + seatCapacity) : seatNumber;
      }

      if (!baseInfo.name && baseInfo.status === 'occupied') baseInfo.name = 'Active table';
      openTableInfoPanel(baseInfo);
      updateSelectionMission();

      const lookupTableNumber = String(tableNumber || (statusEntry && statusEntry.tableNumber) || '').trim();
      Promise.resolve().then(async function(){
        try {
          await ensureLiveHostStatuses(false);
          if (requestId !== __hostTableInfoRequestId) return;

          let refreshedEntry = getStatusEntryBySelection(tableId, tableNumber) || statusEntry;
          const mergedInfo = {
            tableNumber: baseInfo.tableNumber,
            name: baseInfo.name,
            people: baseInfo.people,
            time: baseInfo.time,
            status: baseInfo.status,
          };

          if (refreshedEntry) {
            mergedInfo.tableNumber = refreshedEntry.tableNumber || mergedInfo.tableNumber;
            mergedInfo.status = normalizeHostTableStatus(refreshedEntry.status || mergedInfo.status || 'empty');
            if (!mergedInfo.name) mergedInfo.name = refreshedEntry.guestName || '';
            if (mergedInfo.people === '' || mergedInfo.people == null) mergedInfo.people = refreshedEntry.guestCount !== '' ? refreshedEntry.guestCount : '';
            if (!mergedInfo.time) mergedInfo.time = refreshedEntry.reservationTime || '';
          }

          try {
            const exactUrl = new URL('/api/host/table/status', window.location.origin);
            exactUrl.searchParams.set('restaurantId', rid);
            if (tableId) exactUrl.searchParams.set('tableId', tableId);
            if (lookupTableNumber) exactUrl.searchParams.set('table', lookupTableNumber);
            const exactRes = await fetch(exactUrl.toString(), {
              method: 'GET',
              headers: { 'Accept': 'application/json' },
            });
            const exactData = await exactRes.json().catch(function(){ return {}; });
            if (requestId !== __hostTableInfoRequestId) return;

            if (exactRes.ok && exactData && exactData.ok && exactData.status) {
              refreshedEntry = setStatusEntry(exactData.status);
              if (refreshedEntry) {
                mergedInfo.tableNumber = refreshedEntry.tableNumber || mergedInfo.tableNumber;
                mergedInfo.status = normalizeHostTableStatus(refreshedEntry.status || mergedInfo.status || 'empty');
                mergedInfo.name = refreshedEntry.guestName || mergedInfo.name || '';
                if (refreshedEntry.guestCount !== '' && refreshedEntry.guestCount != null) mergedInfo.people = refreshedEntry.guestCount;
                mergedInfo.time = refreshedEntry.reservationTime || mergedInfo.time || '';
              }
            }
          } catch (e) {
            console.warn('[HOST] exact shared status lookup failed', e);
          }

          const shouldLookupHostInfo = !!lookupTableNumber && (
            mergedInfo.status === 'occupied' ||
            mergedInfo.name === '' ||
            mergedInfo.people === '' ||
            mergedInfo.time === ''
          );

          if (shouldLookupHostInfo) {
            try {
              const url = new URL('/api/host/table/info', window.location.origin);
              url.searchParams.set('restaurantId', rid);
              url.searchParams.set('table', lookupTableNumber);
              const res = await fetch(url.toString(), {
                method: 'GET',
                headers: { 'Accept': 'application/json' },
              });
              const data = await res.json().catch(function(){ return {}; });
              if (requestId !== __hostTableInfoRequestId) return;

              if (res.ok && data && data.ok) {
                refreshedEntry = setStatusEntry({
                  tableId: tableId,
                  tableNumber: Number(lookupTableNumber || 0) || tableNumber,
                  status: mergedInfo.status === 'reserved' || mergedInfo.status === 'dirty' ? mergedInfo.status : 'occupied',
                  guestName: data.name || data.guestName || mergedInfo.name || '',
                  guestCount: (data.people != null && data.people !== '') ? data.people : mergedInfo.people,
                  reservationTime: data.time || mergedInfo.time || '',
                });
                mergedInfo.tableNumber = tableNumber || (refreshedEntry && refreshedEntry.tableNumber) || mergedInfo.tableNumber;
                mergedInfo.name = data.name || data.guestName || mergedInfo.name || '';
                mergedInfo.people = (data.people != null && data.people !== '') ? data.people : mergedInfo.people;
                mergedInfo.time = data.time || mergedInfo.time || '';
                if (mergedInfo.status !== 'reserved' && mergedInfo.status !== 'dirty') mergedInfo.status = 'occupied';
              } else {
                await ensureLiveHostStatuses(true);
                refreshedEntry = getStatusEntryBySelection(tableId, tableNumber) || refreshedEntry;
                if (refreshedEntry) {
                  mergedInfo.status = normalizeHostTableStatus(refreshedEntry.status || mergedInfo.status || 'empty');
                  if (!mergedInfo.name) mergedInfo.name = refreshedEntry.guestName || '';
                  if (mergedInfo.people === '' || mergedInfo.people == null) mergedInfo.people = refreshedEntry.guestCount !== '' ? refreshedEntry.guestCount : '';
                  if (!mergedInfo.time) mergedInfo.time = refreshedEntry.reservationTime || '';
                }
              }
            } catch (e) {
              console.warn('[HOST] table info lookup failed, using local fallback', e);
            }
          }

          if (!mergedInfo.name && mergedInfo.status === 'occupied') mergedInfo.name = 'Active table';
          if (requestId === __hostTableInfoRequestId) {
            openTableInfoPanel(mergedInfo);
            updateSelectionMission();
          }
        } catch (e) {
          console.warn('[HOST] syncTableInfoPanelFromSelection background refresh failed', e);
        }
      });
    } catch (e) {
      console.warn('[HOST] syncTableInfoPanelFromSelection error', e);
    }
  }


  function barDebug(label, payload){
    try {
      console.log('[BAR_DEBUG][host-ui] ' + label, payload || {});
    } catch (e) {}
  }

  window.addEventListener("sb-floor-selection", function(ev){
    try {
      const d = (ev && ev.detail) ? ev.detail : {};
      let nums = Array.isArray(d.tableNumbers) ? d.tableNumbers : [];
      const ids = Array.isArray(d.tableIds) ? d.tableIds : [];

      // If the embedded view couldn't provide numbers, derive from tableIds
      if ((!nums || nums.length === 0) && ids.length) {
        nums = ids
          .map(function(id){ return __SB_TABLE_ID_TO_NUMBER[String(id)] })
          .map(Number)
          .filter(function(n){ return Number.isFinite(n) && n > 0; });
      }

      state.selectedTables = new Set((nums || []).map(Number).filter(n => Number.isFinite(n) && n > 0));
      state.selectedTableIds = new Set((ids || []).map(String).filter(Boolean));
      state.selectedBar = d && d.isBarSeat ? {
        tableId: ids[0] ? String(ids[0]) : "",
        tableNumber: nums[0] ? Number(nums[0]) : Number(__SB_TABLE_ID_TO_NUMBER[String(ids[0] || "")] || 0),
        seatId: String(d.barSeatId || ""),
        seatNumber: Number(d.barSeatNumber || 0),
        capacity: Number(d.barSeatCapacity || 0),
        occupiedSeatNumbers: Array.isArray(d.occupiedBarSeatNumbers) ? d.occupiedBarSeatNumbers.map(Number).filter(function(n){ return Number.isFinite(n) && n > 0; }) : [],
      } : null;
      barDebug('selection', {
        detail: d,
        selectedTables: Array.from(state.selectedTables || []),
        selectedTableIds: Array.from(state.selectedTableIds || []),
        selectedBar: state.selectedBar,
      });
      updateSelectionMission();
      syncTableInfoPanelFromSelection(d);
    } catch (e) {
      console.warn("[HOST] selection event error", e);
    }
  });

  async function applyRestaurantSystemTime(mode){
    try {
      const body = mode === "reset"
        ? { mode: "reset" }
        : { date: systemDateInput && systemDateInput.value, time: systemTimeInput && systemTimeInput.value };
      const res = await fetch(`/api/restaurants/${encodeURIComponent(rid)}/system-time`, {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) throw new Error(data.error || ("HTTP " + res.status));
      if (systemPreview) systemPreview.textContent = `${data.time || ""}`;
      if (systemStatus) systemStatus.textContent = mode === "reset"
        ? "<%= tt('host.system_time.reset_done', 'Returned to real time. Refreshing the host view…') %>"
        : "<%= tt('host.system_time.saved', 'Restaurant time saved. Refreshing the host view…') %>";
      window.location.reload();
    } catch (e) {
      console.error(e);
      alert("<%= tt('host.system_time.error', 'Unable to update restaurant time.') %>");
    }
  }

  if (systemApplyBtn) {
    systemApplyBtn.addEventListener("click", function(){
      if (!systemDateInput || !systemDateInput.value || !systemTimeInput || !systemTimeInput.value) {
        alert("<%= tt('host.system_time.pick_both', 'Please choose both date and time.') %>");
        return;
      }
      applyRestaurantSystemTime("set");
    });
  }
  if (systemNowBtn) {
    systemNowBtn.addEventListener("click", function(){
      applyRestaurantSystemTime("reset");
    });
  }

// צד פרטי שולחן
  const tableInfoPanel = document.getElementById("table-info-panel");
  const tableInfoBackdrop = document.getElementById("table-info-backdrop");
  const tipCloseBtn = document.getElementById("tip-close-btn");
  const tipTableNumber = document.getElementById("tip-table-number");
  const tipTableNumberHero = document.getElementById("tip-table-number-hero");
  const tipGuestName = document.getElementById("tip-guest-name");
  const tipPeople = document.getElementById("tip-people");
  const tipTime = document.getElementById("tip-time");
  const tipStatus = document.getElementById("tip-status");
  const tipStatusText = document.getElementById("tip-status-text");
  const tipStatusCopy = document.getElementById("tip-status-copy");
  const tipSummaryLine = document.getElementById("tip-summary-line");
  const tipGuidance = document.getElementById("tip-guidance");
  const tableInfoHero = document.getElementById("table-info-hero");

  function mapStatusToLabel(status){
    const s = (status || "").toLowerCase();
    if (s === "occupied" || s === "open") return "<%= tt('host.status.occupied', 'Occupied') %>";
    if (s === "reserved") return "<%= tt('host.status.reserved', 'Reserved') %>";
    if (s === "dirty") return "<%= tt('host.status.dirty', 'Needs Cleaning') %>";
    if (s === "empty" || s === "free") return "<%= tt('host.status.empty', 'Empty') %>";
    return status || "<%= tt('host.status.unknown', 'Unknown') %>";
  }

  function mapStatusToClass(status){
    const s = (status || "").toLowerCase();
    if (s === "occupied" || s === "open") return "tip-status-occupied";
    if (s === "reserved") return "tip-status-reserved";
    if (s === "dirty") return "tip-status-dirty";
    if (s === "empty" || s === "free") return "tip-status-empty";
    return "tip-status-unknown";
  }

  function openTableInfoPanel(info){
    if (!tableInfoPanel) return;
    const tableNumberText = info.tableNumber != null ? info.tableNumber : "—";
    const guestNameText = info.name || "—";
    const peopleText = (info.people != null && info.people !== "") ? info.people : "—";
    const timeText = info.time || "—";
    const statusLabel = mapStatusToLabel(info.status);
    const statusClass = mapStatusToClass(info.status);
    const normalizedStatus = String(info.status || '').toLowerCase();

    let statusCopy = "<%= tt('host.table_info_note', 'Information is taken from the last reservation assigned to this table.') %>";
    let summaryLine = "<%= tt('host.table_panel_default_summary', 'Review the latest assignment and table state before the next action.') %>";
    let guidance = "<%= tt('host.table_panel_default_guidance', 'Use this panel to quickly verify who is seated here and what should happen next.') %>";

    if (normalizedStatus === 'occupied' || normalizedStatus === 'open') {
      statusCopy = "<%= tt('host.table_panel_occupied_copy', 'Guests are currently dining here.') %>";
      summaryLine = "<%= tt('host.table_panel_occupied_summary', 'This table is active now. Double-check the party and timing before making changes.') %>";
      guidance = "<%= tt('host.table_panel_occupied_guidance', 'Keep the table occupied unless service or reassignment requires an update.') %>";
    } else if (normalizedStatus === 'reserved') {
      statusCopy = "<%= tt('host.table_panel_reserved_copy', 'This table is being held for an upcoming arrival.') %>";
      summaryLine = "<%= tt('host.table_panel_reserved_summary', 'The table is reserved. Confirm the guest and arrival time before reusing it.') %>";
      guidance = "<%= tt('host.table_panel_reserved_guidance', 'Keep the table ready and avoid assigning walk-ins unless the reservation changes.') %>";
    } else if (normalizedStatus === 'dirty') {
      statusCopy = "<%= tt('host.table_panel_dirty_copy', 'This table needs cleanup before the next seating.') %>";
      summaryLine = "<%= tt('host.table_panel_dirty_summary', 'The table is blocked by housekeeping. Wait until it is marked ready again.') %>";
      guidance = "<%= tt('host.table_panel_dirty_guidance', 'Coordinate with the floor team, then mark it empty once it is ready.') %>";
    } else if (normalizedStatus === 'empty' || normalizedStatus === 'free') {
      statusCopy = "<%= tt('host.table_panel_empty_copy', 'This table is open for the next seating decision.') %>";
      summaryLine = "<%= tt('host.table_panel_empty_summary', 'The table is currently available. It can be used for the next suitable reservation.') %>";
      guidance = "<%= tt('host.table_panel_empty_guidance', 'Use the seating flow to pair this table with the right guest or keep it available.') %>";
    }

    tipTableNumber.textContent = tableNumberText;
    if (tipTableNumberHero) tipTableNumberHero.textContent = tableNumberText;
    tipGuestName.textContent = guestNameText;
    tipPeople.textContent = peopleText;
    tipTime.textContent = timeText;
    if (tipStatusText) tipStatusText.textContent = statusLabel;
    if (tipStatusCopy) tipStatusCopy.textContent = statusCopy;
    if (tipSummaryLine) tipSummaryLine.textContent = summaryLine;
    if (tipGuidance) tipGuidance.textContent = guidance;

    // סטטוס עם באדג׳
    const clsBase = ["tip-status-badge","tip-status-empty","tip-status-occupied","tip-status-reserved","tip-status-dirty","tip-status-unknown"];
    if (tipStatus) {
      tipStatus.textContent = statusLabel;
      tipStatus.className = clsBase[0] + " " + statusClass;
    }
    if (tableInfoHero) tableInfoHero.setAttribute('data-status', normalizedStatus || 'unknown');

    tableInfoPanel.classList.add("open");
    tableInfoBackdrop.classList.add("open");
    tableInfoPanel.setAttribute("aria-hidden","false");
  }

  function closeTableInfoPanel(){
    if (!tableInfoPanel) return;
    tableInfoPanel.classList.remove("open");
    tableInfoBackdrop.classList.remove("open");
    tableInfoPanel.setAttribute("aria-hidden","true");
  }

  if (tipCloseBtn) {
    tipCloseBtn.addEventListener("click", closeTableInfoPanel);
  }
  if (tableInfoBackdrop) {
    tableInfoBackdrop.addEventListener("click", closeTableInfoPanel);
  }

  // ---------- עזר: שחרור שולחן/ות תקועים דרך ה-API ----------
  async function forceUnseatTables(rid, tables){
    if (!tables || !tables.length) return { ok: false };

    try {
      const url = new URL("/api/host/table/unseat", window.location.origin);
      url.searchParams.set("restaurantId", rid);
      url.searchParams.set("tables", tables.join(","));

      const res = await fetch(url.toString(), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          restaurantId: rid,
          tables: tables,
        }),
      });

      const data = await res.json().catch(() => ({}));
      console.log("[HOST] forceUnseatTables result", res.status, data);

      if (!res.ok || !data.ok) {
        throw new Error(data.error || ("HTTP " + res.status));
      }
      return data;
    } catch (e) {
      console.error("[HOST] forceUnseatTables error", e);
      throw e;
    }
  }

  // בחירת הזמנה (radio)
  if (resvList) {
    resvList.addEventListener("change", function(ev){
      const input = ev.target;
      if (input && input.name === "resv") {
        state.selectedResId = input.value;
        updateSelectionMission();
      }
    });

    // כפתורי ביטול / לא הגיע
    resvList.addEventListener("click", async function(ev){
      const btn = ev.target;
      if (!(btn instanceof HTMLElement)) return;

      const action = btn.dataset.action;
      if (!action) return;

      ev.preventDefault();
      ev.stopPropagation();

      const li = btn.closest("li[data-res-id]");
      if (!li) return;
      const resId = li.getAttribute("data-res-id");
      if (!resId) return;

      let status = "";
      if (action === "cancel") {
        if (!confirm("<%= tt('host.confirm_cancel', 'Mark this reservation as cancelled?') %>")) return;
        status = "cancelled";
      } else if (action === "no_show") {
        if (!confirm("<%= tt('host.confirm_no_show', `Mark this reservation as 'No Show'?`) %>")) return;
        status = "no_show";
      } else {
        return;
      }

      try {
        const url = new URL("/api/host/reservation/status", window.location.origin);
        url.searchParams.set("restaurantId", rid);
        url.searchParams.set("reservationId", resId);
        url.searchParams.set("status", status);

        const res = await fetch(url.toString(), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            restaurantId: rid,
            reservationId: resId,
            status,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.ok) {
          alert("<%= tt('host.err_update_status', 'Error updating reservation status') %>: " + (data.error || res.status));
          return;
        }

        // אם ההזמנה שסימנו היא גם זו שנבחרה – ננקה מה-state
        const radio = li.querySelector('input[name="resv"]');
        if (radio && radio.checked) {
          state.selectedResId = null;
        }

        // הסרת השורה מה-UI
        const ul = li.parentElement;
        ul.removeChild(li);
        if (!ul.querySelector("li")) {
          const p = document.createElement("p");
          p.className = "muted";
          p.textContent = "<%= tt('host.no_reservations', 'No reservations for today at this restaurant.') %>";
          ul.replaceWith(p);
        }
        applyReservationFilters();
        updateSelectionMission();
      } catch (e) {
        console.error(e);
        alert("<%= tt('host.err_network_status', 'Network error while updating status.') %>");
      }
    });
  }

  applyReservationFilters();
  updateSelectionMission();

  function getSelectedReservationName(){
    if (!state.selectedResId || !resvList) return "";
    const li = resvList.querySelector('li[data-res-id="'+state.selectedResId+'"]');
    if (!li) return "";
    const nameEl = li.querySelector(".resv-name");
    return (nameEl && nameEl.textContent || "").trim();
  }

  function getSelectedReservationPeople(){
    if (!state.selectedResId || !resvList) return 1;
    const li = resvList.querySelector('li[data-res-id="'+state.selectedResId+'"]');
    if (!li) return 1;
    const n = Number(li.dataset.people || 1);
    return Number.isFinite(n) && n > 0 ? n : 1;
  }

  function getCheckedReservationId(){
    try {
      if (!resvList) return "";
      const checked = resvList.querySelector('input[name="resv"]:checked');
      return checked ? String(checked.value || "").trim() : "";
    } catch (e) {
      return "";
    }
  }

  function getSelectedBarFromDataset(){
    try {
      const root = document.getElementById('sb-floor-root');
      const ds = root && root.dataset ? root.dataset : null;
      if (!ds) return null;
      const tableId = String(ds.selectedTableId || ds.selectedBarTableId || '').trim();
      const tableNumber = Number(ds.selectedTableNumber || ds.selectedBarTableNumber || 0) || 0;
      const seatId = String(ds.selectedBarSeatId || '').trim();
      const seatNumber = Number(ds.selectedBarSeatNumber || 0) || 0;
      const capacity = Number(ds.selectedBarSeatCapacity || 0) || 0;
      const occupiedSeatNumbers = String(ds.occupiedBarSeatNumbers || '')
        .split(',')
        .map(function(v){ return Number(String(v || '').trim()); })
        .filter(function(n){ return Number.isFinite(n) && n > 0; });
      if (!seatId && !tableId && !tableNumber) return null;
      return { tableId, tableNumber, seatId, seatNumber, capacity, occupiedSeatNumbers };
    } catch (e) {
      return null;
    }
  }

  function findAdjacentBarSeats(anchorSeatNumber, peopleCount, capacity, occupiedSeatNumbers){
    const cap = Math.max(1, Number(capacity || 1));
    const need = Math.max(1, Math.min(cap, Number(peopleCount || 1)));
    const anchor = Math.max(1, Math.min(cap, Number(anchorSeatNumber || 1)));
    const occupied = new Set((occupiedSeatNumbers || []).map(Number).filter(function(n){ return Number.isFinite(n) && n > 0; }));
    const starts = [];
    for (let delta = 0; delta < cap; delta++) {
      const left = anchor - delta;
      const right = anchor + delta;
      if (left >= 1 && left <= cap - need + 1) starts.push(left);
      if (right !== left && right >= 1 && right <= cap - need + 1) starts.push(right);
    }
    for (const start of starts) {
      const seq = Array.from({ length: need }, function(_, idx){ return start + idx; });
      if (seq.indexOf(anchor) < 0) continue;
      if (seq.every(function(seatNo){ return !occupied.has(seatNo); })) return seq;
    }
    for (let start = 1; start <= cap - need + 1; start++) {
      const seq = Array.from({ length: need }, function(_, idx){ return start + idx; });
      if (seq.every(function(seatNo){ return !occupied.has(seatNo); })) return seq;
    }
    return null;
  }

  function toggleTableSelection(tableNumber, btnEl){
    const tn = Number(tableNumber);
    if (!Number.isFinite(tn) || !btnEl) return;

    if (state.selectedTables.has(tn)) {
      state.selectedTables.delete(tn);
      btnEl.classList.remove("selected");
    } else {
      state.selectedTables.add(tn);
      btnEl.classList.add("selected");
    }
  }

  async function loadFloor(){
    const holder = document.getElementById("floor");
    if (!holder) return;
    holder.innerHTML = "";

    try{
      const res = await fetch(`/api/floor-plans/${encodeURIComponent(rid)}`);
      if (!res.ok) {
        const p = document.createElement("p");
        p.className = "muted";
        p.textContent = "<%= tt('host.no_floor_plan', 'No floor plan has been defined for this restaurant.') %>";
        holder.appendChild(p);
        return;
      }
      const plan = await res.json();

      const gridRows = Number(plan.gridRows || 8);
      const gridCols = Number(plan.gridCols || 10);
      const tables = Array.isArray(plan.tables) ? plan.tables : [];
      const tableStatuses = Array.isArray(plan.tableStatuses) ? plan.tableStatuses : [];

      const statusMap = new Map();
      const guestMap = new Map();

      tableStatuses.forEach(function(s){
        const tn = Number(s.tableNumber);
        if (!Number.isFinite(tn)) return;

        const st = s.status || "empty";
        statusMap.set(tn, st);

        const gName = s.guestName || s.name || s.customerName || null;
        if (gName) {
          guestMap.set(tn, String(gName));
        }
      });

      if (!tables.length) {
        const p = document.createElement("p");
        p.className = "muted";
        p.textContent = "<%= tt('host.no_tables_defined', 'No tables defined in the restaurant map.') %>";
        holder.appendChild(p);
        return;
      }

      const grid = document.createElement("div");
      grid.className = "floor-grid";
      grid.style.setProperty("--rows", gridRows);
      grid.style.setProperty("--cols", gridCols);
      holder.appendChild(grid);

      tables.forEach(function(t){
        const num = Number(t.tableNumber);
        const status = statusMap.get(num) || "empty";
        const seats = Number(t.seats || 0);
        const guestName = guestMap.get(num) || "";

        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "table " + status;
        btn.dataset.tableNumber = String(num);

        const capText = seats > 0 ? (seats + " <%= tt('host.seats', 'seats') %>") : "";

        btn.innerHTML = `
          <div class="table-num">${num}</div>
          <div class="table-cap">${capText}</div>
          ${guestName ? `<div class="table-guest">${guestName}</div>` : ""}
        `;

        btn.style.gridRow = (t.gridY + 1) + " / span " + (t.spanY || 1);
        btn.style.gridColumn = (t.gridX + 1) + " / span " + (t.spanX || 1);

        // לחיצה על שולחן
        btn.addEventListener("click", async function(){
          const currentStatus = statusMap.get(num) || "empty";

          // שולחן פנוי – בחירה/ביטול להושבה
          if (currentStatus === "empty") {
            closeTableInfoPanel(); // אם היה פתוח, נסגור
            toggleTableSelection(num, btn);
            return;
          }

          // שולחן תפוס/שמורה/מלוכלך – נטען מידע מפורט מהשרת
          try {
            const url = new URL("/api/host/table/info", window.location.origin);
            url.searchParams.set("restaurantId", rid);
            url.searchParams.set("table", String(num));

            const res = await fetch(url.toString(), {
              method: "GET",
              headers: { "Accept": "application/json" },
            });

            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data.ok) {
              const msg = data && data.error ? data.error : res.status;
              alert("<%= tt('host.err_load_table', 'Cannot load table details') %>: " + msg);
              return;
            }

            openTableInfoPanel({
              tableNumber: num,
              name: data.name || data.guestName || "",
              people: data.people,
              time: data.time,
              status: currentStatus,
            });
          } catch (e) {
            console.error(e);
            alert("<%= tt('host.err_load_table_general', 'Error loading table details.') %>");
          }
        });

        grid.appendChild(btn);
      });
    }catch(e){
      console.error(e);
      const p = document.createElement("p");
      p.className = "muted";
      p.textContent = "<%= tt('host.err_load_map', 'Error loading the restaurant map.') %>";
      holder.appendChild(p);
    }
  }

  async function seatSelected(){
    const effectiveReservationId = String(state.selectedResId || getCheckedReservationId() || '').trim();
    if (!effectiveReservationId) {
      alert("<%= tt('host.err_select_reservation', 'Please select a reservation first.') %>");
      return;
    }
    state.selectedResId = effectiveReservationId;

    const effectiveBar = (state.selectedBar && state.selectedBar.seatId)
      ? state.selectedBar
      : getSelectedBarFromDataset();

    if (effectiveBar && effectiveBar.seatId) {
      const guestName = getSelectedReservationName();
      const peopleCount = getSelectedReservationPeople();
      const capacity = Number(effectiveBar.capacity || 0) || Math.max(peopleCount, Number(effectiveBar.seatNumber || 1), 1);
      const occupiedSeatNumbers = Array.isArray(effectiveBar.occupiedSeatNumbers) ? effectiveBar.occupiedSeatNumbers : [];
      const seatNumbers = findAdjacentBarSeats(
        Number(effectiveBar.seatNumber || 0),
        peopleCount,
        capacity,
        occupiedSeatNumbers
      );
      barDebug('seatSelected.compute', {
        reservationId: effectiveReservationId,
        guestName,
        peopleCount,
        selectedBar: effectiveBar,
        computedSeatNumbers: seatNumbers,
      });
      if (!seatNumbers || !seatNumbers.length) {
        alert("<%= tt('host.err_no_adjacent_bar_seats', 'Not enough adjacent free seats at the bar for this reservation.') %>");
        return;
      }

      const resolvedTableId = String(effectiveBar.tableId || String(effectiveBar.seatId || '').split(':seat:')[0] || '').trim();
      const resolvedTableNumber = Number(effectiveBar.tableNumber || __SB_TABLE_ID_TO_NUMBER[String(resolvedTableId || '')] || 0);
      const seatIds = seatNumbers.map(function(seatNo){
        return String(resolvedTableId || '') + ':seat:' + String(seatNo);
      }).filter(Boolean);

      if (!confirm(`<%= tt('host.confirm_seat_bar', 'Seat the reservation at bar seats') %> ${seatNumbers.join(', ')}?`)) return;

      try {
        const payload = {
          restaurantId: rid,
          reservationId: effectiveReservationId,
          table: resolvedTableNumber,
          tableId: resolvedTableId,
          seatIds,
          guestName,
        };
        barDebug('seatSelected.payload', payload);
        const urls = [
          '/api/host/seat-bar',
          `/api/host/${encodeURIComponent(rid)}/seat-bar`,
          '/api/host/seat-bar/',
          `/api/host/${encodeURIComponent(rid)}/seat-bar/`,
        ];
        let res = null;
        let data = {};
        for (const rawUrl of urls) {
          const reqUrl = new URL(rawUrl, window.location.origin);
          reqUrl.searchParams.set('restaurantId', rid);
          reqUrl.searchParams.set('reservationId', effectiveReservationId);
          if (resolvedTableNumber > 0) reqUrl.searchParams.set('table', String(resolvedTableNumber));
          if (resolvedTableId) reqUrl.searchParams.set('tableId', resolvedTableId);
          if (guestName) reqUrl.searchParams.set('guestName', guestName);
          seatIds.forEach(function(seatId){ reqUrl.searchParams.append('seatIds', seatId); });
          reqUrl.searchParams.set('seatIdsCsv', seatIds.join(','));
          barDebug('seatSelected.request', { url: reqUrl.toString(), payload });
          res = await fetch(reqUrl.toString(), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(payload),
          });
          data = await res.json().catch(function(){ return {}; });
          barDebug('seatSelected.response', { url: reqUrl.toString(), status: res.status, ok: res.ok, data });
          if (res.ok && data.ok) break;
          if (res.status !== 404) break;
        }
        if (!res || !res.ok || !data.ok) {
          barDebug('seatSelected.failed', {
            payload,
            responseStatus: res ? res.status : null,
            responseData: data,
          });
          alert("<%= tt('host.err_seating', 'Seating error') %>: " + (data.error || (res ? res.status : 'request_failed')));
          return;
        }
        barDebug('seatSelected.success', { seatNumbers, data });
        alert(`<%= tt('host.success_seat_bar', 'Reservation seated at bar seats') %> ${seatNumbers.join(', ')}.`);
        window.location.reload();
        return;
      } catch (e) {
        console.error(e);
        alert("<%= tt('host.err_network_seat', 'Network error during seating.') %>");
        return;
      }
    }


    if (!state.selectedTables.size) {
      // If we have selected table IDs but no numbers, derive the numbers from mapping
      try {
        if (state.selectedTableIds && state.selectedTableIds.size) {
          const derived = Array.from(state.selectedTableIds.values())
            .map(id => __SB_TABLE_ID_TO_NUMBER[String(id)])
            .map(Number)
            .filter(n => Number.isFinite(n) && n > 0);
          if (derived.length) state.selectedTables = new Set(derived);
        }
      } catch (e) {}

      // Fallback: read selection from floor-view app dataset
      try {
        const root = document.getElementById("sb-floor-root");
        const ds = root && root.dataset ? root.dataset : {};
        const tn = (ds.selectedTableNumber || "").trim();
        if (tn) state.selectedTables = new Set([Number(tn)]);
        const tid = (ds.selectedTableId || "").trim();
        if (tid) state.selectedTableIds = new Set([tid]);
        state.selectedBar = null;
      } catch (e) {}
    }
    if (!state.selectedTables.size) {
      alert("<%= tt('host.err_select_table', 'Please select at least one table.') %>");
      return;
    }

    const tables = Array.from(state.selectedTables.values());
    const guestName = getSelectedReservationName();

    const msg = tables.length === 1
      ? `<%= tt('host.confirm_seat_single', 'Seat the reservation at table') %> ${tables[0]}?`
      : `<%= tt('host.confirm_seat_multi', 'Seat the reservation at tables') %> ${tables.join(", ")} (<%= tt('host.table_merge', 'table merge') %>)?`;
    if (!confirm(msg)) return;

    async function doSeatOnce() {
      let res, data;

      if (tables.length === 1) {
        const url = new URL("/api/host/seat", window.location.origin);
        url.searchParams.set("restaurantId", rid);
        url.searchParams.set("reservationId", state.selectedResId);
        url.searchParams.set("table", String(tables[0]));

        res = await fetch(url.toString(), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            restaurantId: rid,
            reservationId: state.selectedResId,
            table: tables[0],
            guestName,
          }),
        });
      } else {
        const url = new URL("/api/host/seat-multi", window.location.origin);
        url.searchParams.set("restaurantId", rid);
        url.searchParams.set("reservationId", state.selectedResId);
        url.searchParams.set("tables", tables.join(","));

        res = await fetch(url.toString(), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            restaurantId: rid,
            reservationId: state.selectedResId,
            tables,
            guestName,
          }),
        });
      }

      data = await res.json().catch(() => ({}));
      return { res, data };
    }

    try {
      // ניסיון ראשון
      let { res, data } = await doSeatOnce();

      if (!res.ok || !data.ok) {
        if (data && data.error === "table_already_seated") {
          const confirmUnseat = confirm(
            "<%= tt('host.confirm_unseat', 'The table is marked as occupied (probably from a previous session). Release it and allow re-seating?') %>"
          );
          if (!confirmUnseat) return;

          // שחרור השולחן /ות
          await forceUnseatTables(rid, tables);

          // ניסיון שני אחרי שחרור
          const second = await doSeatOnce();
          res = second.res;
          data = second.data;

          if (!res.ok || !data.ok) {
            alert("<%= tt('host.err_seat_after_release', 'Error seating after table release') %>: " + (data.error || res.status));
            return;
          }
        } else {
          alert("<%= tt('host.err_seating', 'Seating error') %>: " + (data.error || res.status));
          return;
        }
      }

      // === הצלחה: עדכון ה-UI ===
      const floor = document.getElementById("floor");
      if (floor) {
        tables.forEach(function(tn){
          const btn = floor.querySelector('.table[data-table-number="'+tn+'"]');
          if (!btn) return;
          btn.classList.remove("empty", "selected");
          btn.classList.add("occupied");

          if (guestName) {
            let guestDiv = btn.querySelector(".table-guest");
            if (!guestDiv) {
              guestDiv = document.createElement("div");
              guestDiv.className = "table-guest";
              btn.appendChild(guestDiv);
            }
            guestDiv.textContent = guestName;
          }
        });
      }

      // הסרת ההזמנה מהרשימה
      if (resvList && state.selectedResId) {
        const li = resvList.querySelector('li[data-res-id="'+state.selectedResId+'"]');
        if (li) {
          const ul = li.parentElement;
          const radio = li.querySelector('input[name="resv"]');
          if (radio && radio.checked) {
            state.selectedResId = null;
          }
          ul.removeChild(li);
          if (!ul.querySelector("li")) {
            const p = document.createElement("p");
            p.className = "muted";
            p.textContent = "<%= tt('host.no_reservations', 'No reservations for today at this restaurant.') %>";
            ul.replaceWith(p);
          }
        }
      }

      state.selectedTables.clear();
      state.selectedTableIds.clear();
      state.selectedBar = null;
      try { window.dispatchEvent(new CustomEvent("sb-floor-clear-selection")); } catch(_e) {}
      closeTableInfoPanel();
      applyReservationFilters();
      updateSelectionMission();

      alert(
        tables.length === 1
          ? `<%= tt('host.success_seat_single', 'Reservation seated at table') %> ${tables[0]}. <%= tt('host.check_opened', 'Check opened.') %>`
          : `<%= tt('host.success_seat_multi', 'Reservation seated at tables') %> ${tables.join(", ")}. <%= tt('host.checks_opened', 'Checks opened accordingly.') %>`
      );
    } catch (e) {
      console.error(e);
      alert("<%= tt('host.err_network_seat', 'Network error during seating.') %>");
    }
  }

  if (seatBtn) {
    seatBtn.addEventListener("click", function(){
      seatSelected();
    });
  }

  async function markStatusForSelected(status){
    let ids = Array.from(state.selectedTableIds.values());
    if (!ids.length) {
      // Fallback: read selection from floor-view app dataset
      try {
        const root = document.getElementById("sb-floor-root");
        const ds = root && root.dataset ? root.dataset : {};
        const tid = (ds.selectedTableId || "").trim();
        if (tid) state.selectedTableIds = new Set([tid]);
      } catch (e) {}
      ids = Array.from(state.selectedTableIds.values());
    }
    if (!ids.length) {
      alert('<%= tt("host.err_select_table", "Please select at least one table on the map.") %>');
      return;
    }

    try{
      await Promise.all(ids.map(async (tid) => {
        const res = await fetch(`/api/tables/${encodeURIComponent(rid)}/${encodeURIComponent(tid)}/status`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || ("HTTP " + res.status));
        }
      }));

      const numbers = getEffectiveSelectedTableNumbers();
      ids.forEach(function(tid, idx){
        setStatusEntry({
          tableId: tid,
          tableNumber: Number(numbers[idx] || numbers[0] || 0) || 0,
          status: status,
        });
      });
      __hostStatusesLoadedAt = 0;
      updateSelectionMission();
      try { await syncTableInfoPanelFromSelection({ tableIds: ids, tableNumbers: numbers }); } catch (_e) {}
      try { window.dispatchEvent(new Event("sb-floor-refresh")); } catch(_e) {}
    } catch (e) {
      console.error(e);
      alert('<%= tt("host.err_update_status_prefix", "Unable to update table status") %>: ' + (e && e.message ? e.message : "unknown"));
    }
  }

  if (markOccupiedBtn) {
    markOccupiedBtn.addEventListener("click", function(){
      markStatusForSelected("occupied");
    });
  }
  if (markReservedBtn) {
    markReservedBtn.addEventListener("click", function(){
      markStatusForSelected("reserved");
    });
  }
  if (markDirtyBtn) {
    markDirtyBtn.addEventListener("click", function(){
      markStatusForSelected("dirty");
    });
  }
  if (markEmptyBtn) {
    markEmptyBtn.addEventListener("click", function(){
      markStatusForSelected("empty");
    });
  }

  // Floor map is mounted by /dist/floor-view-app.js
})();
</script>

<style>
  .host.container{
    max-width: 1400px;
    margin: 20px auto;
    padding: 0 16px;
  }

  .host-header{
    margin-bottom: 16px;
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:8px;
  }

  .host-header h1{
    margin:0;
    font-size: clamp(20px, 2.6vw, 26px);
  }

  .muted{
    color: var(--ink-muted, #9aa3b2);
  }
  .small{ font-size: 12px; }

  .host-grid{
    display:grid;
    grid-template-columns: minmax(320px, 0.75fr) minmax(760px, 1.25fr);
    gap:16px;
  }

  .card{
    background: var(--panel, #121622);
    border:1px solid var(--bd, #222834);
    border-radius:18px;
    padding:16px;
    color: var(--ink, #e6e8ef);
    box-shadow: 0 10px 30px rgba(0,0,0,.35);
  }

  .list{
    list-style:none;
    padding:0;
    margin:8px 0 0;
  }
  .item{
    border-top:1px solid rgba(255,255,255,.06);
    padding:8px 0;
  }
  .item:first-child{
    border-top:none;
    padding-top:0;
  }

  .radio{
    display:flex;
    gap:8px;
    align-items:flex-start;
    cursor:pointer;
  }
  .radio input{
    margin-top:4px;
  }
  .radio-body{
    display:flex;
    flex-direction:column;
    gap:2px;
  }
  .radio-body .line{
    display:flex;
    gap:4px;
    align-items:center;
    font-size:14px;
  }

  .resv-actions{
    display:flex;
    gap:8px;
    margin-top:4px;
    font-size:12px;
  }
  .link-btn{
    background:none;
    border:none;
    padding:0;
    color:#60a5fa;
    cursor:pointer;
    text-decoration:underline;
    font-size:12px;
  }

  /*
    NOTE:
    #sb-floor-root renders BOTH the map + the right-side Table Details.
    The MAP frame/border is now handled inside the React view (sbv-left).
    So the outer wrapper must NOT clip or frame the Table Details panel.
  */
  .floor-wrapper{
    margin-top: 8px;
    width: 100%;
    height: min(72vh, 780px);
    min-height: 520px;
    display: block;
  }

  .host-actions{
    margin-top:10px;
    display:flex;
    flex-direction:column;
    gap:4px;
    align-items:flex-start;
  }

  .floor-grid{
    display:grid;
    grid-template-rows: repeat(var(--rows,8), 40px);
    grid-template-columns: repeat(var(--cols,10), 40px);
    gap:6px;
    background: rgba(255,255,255,.03);
    padding:6px;
    border-radius:10px;
  }

  .table{
    border:1px solid rgba(255,255,255,.3);
    border-radius:10px;
    padding:6px;
    font-weight:700;
    font-size:14px;
    cursor:pointer;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    backdrop-filter: blur(8px);
    color:#fff;
    text-align:center;
    transition: transform .08s ease, box-shadow .12s ease, background-color .12s ease;
  }

  .table-num{
    font-size: 16px;
    font-weight: 700;
    line-height: 1.1;
  }
  .table-cap{
    font-size: 11px;
    opacity: .86;
    margin-top: 2px;
  }

  .table-guest{
    font-size: 11px;
    margin-top: 4px;
    opacity: 0.95;
    font-weight: 600;
    color: #fff;
    text-shadow: 0 0 4px rgba(0,0,0,.4);
  }

  .table.empty{
    background:#2e7d32;  /* ירוק – פנוי */
  }
  .table.occupied{
    background:#c62828;  /* אדום – תפוס */
  }
  .table.reserved{
    background:#f9a825;  /* צהוב – שמור */
  }
  .table.dirty{
    background:#6a1b9a;  /* סגול – מלוכלך */
  }

  .table.selected{
    outline:2px solid #60a5fa;
    outline-offset:2px;
    transform: translateY(-1px);
    box-shadow: 0 0 0 2px rgba(37,99,235,.5);
  }

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:8px 14px;
    border-radius:12px;
    border:1px solid #1f2937;
    background:transparent;
    color:#e5e7eb;
    cursor:pointer;
    font-size:14px;
    font-weight:600;
    gap:6px;
  }
  .btn.primary{
    background:#3b82f6;
    border-color:#2563eb;
    color:#ffffff;
  }
  .btn.sm{
    padding:6px 12px;
    border-radius:10px;
    font-size:13px;
  }

  @media (max-width: 900px){
    .host-grid{
      grid-template-columns:1fr;
    }
  }

  /* ===== כרטיסיית צד לפרטי שולחן ===== */

  .table-info-backdrop{
    position: fixed;
    inset: 0;
    background: rgba(2,6,23,0.56);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 40;
  }
  .table-info-backdrop.open{
    opacity: 1;
    pointer-events: auto;
  }

  .table-info-panel{
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(420px, 92vw);
    transform: translateX(100%);
    transition: transform .24s ease-out;
    z-index: 41;
    display:flex;
    align-items:stretch;
    justify-content:flex-start;
  }
  .table-info-panel.open{
    transform: translateX(0);
  }

  .table-info-inner{
    position:relative;
    background:
      radial-gradient(circle at top left, rgba(59,130,246,0.18), transparent 38%),
      linear-gradient(180deg, rgba(8,12,24,0.985), rgba(8,12,24,0.965));
    border-left: 1px solid rgba(148,163,184,0.24);
    box-shadow: -24px 0 54px rgba(2,6,23,0.56);
    width: 100%;
    padding: 18px 18px 20px;
    display:flex;
    flex-direction:column;
    gap:14px;
    overflow-y:auto;
  }

  .table-info-inner::before{
    content:"";
    position:absolute;
    inset:0 auto auto 0;
    width:100%;
    height:1px;
    background:linear-gradient(90deg, rgba(96,165,250,0.58), rgba(148,163,184,0));
  }

  .table-info-header{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:12px;
  }

  .tip-label{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.12em;
    color:#93c5fd;
    font-weight:800;
  }
  .tip-title{
    margin-top:6px;
    font-size:24px;
    line-height:1.1;
    font-weight:800;
    color:#f8fafc;
  }

  .tip-close-btn{
    border:1px solid rgba(148,163,184,0.18);
    background: rgba(15,23,42,0.7);
    color:#e5e7eb;
    width:36px;
    height:36px;
    border-radius:999px;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    font-size:15px;
    box-shadow:0 10px 22px rgba(2,6,23,0.2);
  }

  .table-info-hero{
    position:relative;
    display:flex;
    flex-direction:column;
    gap:10px;
    padding:16px;
    border-radius:22px;
    border:1px solid rgba(148,163,184,0.16);
    background:linear-gradient(180deg, rgba(15,23,42,0.84), rgba(15,23,42,0.62));
    box-shadow:0 16px 34px rgba(2,6,23,0.2);
    overflow:hidden;
  }

  .table-info-hero::after{
    content:"";
    position:absolute;
    inset:auto -36px -36px auto;
    width:120px;
    height:120px;
    border-radius:999px;
    background:rgba(59,130,246,0.14);
    filter:blur(10px);
    pointer-events:none;
  }

  .table-info-hero[data-status="occupied"],
  .table-info-hero[data-status="open"]{
    background:linear-gradient(180deg, rgba(127,29,29,0.5), rgba(15,23,42,0.82));
  }
  .table-info-hero[data-status="reserved"]{
    background:linear-gradient(180deg, rgba(120,53,15,0.5), rgba(15,23,42,0.82));
  }
  .table-info-hero[data-status="dirty"]{
    background:linear-gradient(180deg, rgba(88,28,135,0.5), rgba(15,23,42,0.82));
  }
  .table-info-hero[data-status="empty"],
  .table-info-hero[data-status="free"]{
    background:linear-gradient(180deg, rgba(20,83,45,0.46), rgba(15,23,42,0.82));
  }

  .table-info-hero__row{
    display:flex;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
  }

  .table-info-hero__copy{
    font-size:12px;
    color:#cbd5e1;
  }

  .table-info-hero__table{
    font-size:28px;
    font-weight:900;
    color:#ffffff;
    letter-spacing:-0.02em;
  }

  .table-info-hero__subtitle{
    margin:0;
    font-size:13px;
    line-height:1.6;
    color:#dbe7f6;
    max-width:32ch;
  }

  .table-info-grid{
    display:grid;
    grid-template-columns:repeat(2, minmax(0,1fr));
    gap:10px;
  }

  .table-info-card{
    padding:14px;
    border-radius:18px;
    border:1px solid rgba(148,163,184,0.14);
    background:rgba(15,23,42,0.72);
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.03);
    display:flex;
    flex-direction:column;
    gap:8px;
    min-height:88px;
  }

  .table-info-card__label{
    font-size:11px;
    font-weight:800;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:#94a3b8;
  }

  .table-info-card__value{
    font-size:16px;
    line-height:1.35;
    color:#f8fafc;
    word-break:break-word;
  }

  .table-info-body{
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .tip-row{
    display:flex;
    justify-content:space-between;
    gap:10px;
    font-size:13px;
  }
  .tip-row--stacked{
    padding:14px 16px;
    border-radius:18px;
    border:1px solid rgba(148,163,184,0.14);
    background:rgba(15,23,42,0.58);
    flex-direction:column;
    align-items:flex-start;
  }
  .tip-row-label{
    color:#9aa3b2;
    font-weight:800;
    letter-spacing:0.08em;
    text-transform:uppercase;
    font-size:11px;
  }
  .tip-row-value{
    font-weight:600;
  }
  .tip-row-note{
    color:#dbe7f6;
    line-height:1.65;
  }

  .tip-status-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:6px 10px;
    border-radius:999px;
    font-size:11px;
    font-weight:800;
    letter-spacing:0.04em;
    border:1px solid transparent;
  }

  .tip-status-empty{
    background:rgba(34,197,94,0.12);
    border-color:rgba(34,197,94,0.4);
    color:#86efac;
  }
  .tip-status-occupied{
    background:rgba(239,68,68,0.16);
    border-color:rgba(239,68,68,0.55);
    color:#fecaca;
  }
  .tip-status-reserved{
    background:rgba(245,158,11,0.18);
    border-color:rgba(245,158,11,0.6);
    color:#fde68a;
  }
  .tip-status-dirty{
    background:rgba(168,85,247,0.2);
    border-color:rgba(168,85,247,0.7);
    color:#e9d5ff;
  }
  .tip-status-unknown{
    background:rgba(148,163,184,0.18);
    border-color:rgba(148,163,184,0.6);
    color:#e5e7eb;
  }

  .table-info-footer{
    margin-top:auto;
    padding-top:12px;
    border-top:1px solid rgba(148,163,184,0.16);
  }

  @media (max-width: 640px){
    .table-info-panel{
      width:100vw;
    }
    .table-info-inner{
      padding:16px 14px 18px;
    }
    .table-info-grid{
      grid-template-columns:1fr;
    }
    .tip-title{
      font-size:22px;
    }
    .table-info-hero__table{
      font-size:24px;
    }
  }

  .host-grid .floor-wrapper{
    height: min(72vh, 860px);
    /* Do not clip the right-side Table Details panel */
    overflow: visible;
  }
</style>

<style>
  .host.host-ops.container{
    max-width: 1480px;
    margin: 24px auto 40px;
    padding: 0 18px;
  }

  .host-ops .host-shell{
    display:grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr);
    gap:16px;
    margin-bottom:16px;
  }

  .host-ops .host-hero,
  .host-ops .host-time-card,
  .host-ops .host-kpi-card,
  .host-ops .host-reservations-panel,
  .host-ops .host-map-panel{
    background:
      radial-gradient(circle at top right, rgba(59,130,246,.14), transparent 34%),
      linear-gradient(180deg, rgba(15,23,42,.98), rgba(15,23,42,.88));
    border:1px solid rgba(148,163,184,.15);
    box-shadow: 0 24px 60px rgba(2,6,23,.35);
  }

  .host-ops .host-hero{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:18px;
    min-height:140px;
  }

  .host-badge{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:7px 12px;
    border-radius:999px;
    border:1px solid rgba(96,165,250,.26);
    background:rgba(59,130,246,.12);
    color:#bfdbfe;
    font-size:11px;
    font-weight:800;
    letter-spacing:.12em;
    text-transform:uppercase;
  }

  .host-hero__content h1{
    margin:12px 0 8px;
    font-size:clamp(26px, 3vw, 38px);
    line-height:1.05;
  }

  .host-hero__meta{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    justify-content:flex-end;
  }

  .host-hero-chip,
  .host-kpi-card{
    min-width:138px;
    padding:14px 16px;
    border-radius:16px;
    border:1px solid rgba(148,163,184,.15);
    background:rgba(15,23,42,.66);
  }

  .host-hero-chip__label,
  .host-kpi-card__label{
    display:block;
    font-size:11px;
