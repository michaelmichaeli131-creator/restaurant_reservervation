    border-radius:16px;
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.06);
  }
  .sb-mini-label{
    display:block;
    margin-bottom:7px;
    color:#93a8cf;
    font-size:.82rem;
  }
  .sb-mini-stat strong{
    font-size:1.2rem;
    letter-spacing:-.02em;
  }

  .sb-peak-track{
    height:10px;
    border-radius:999px;
    background:rgba(255,255,255,.06);
    overflow:hidden;
    margin-bottom:16px;
  }
  .sb-peak-fill{
    height:100%;
    border-radius:999px;
  }
  .sb-peak-fill.good{ background:linear-gradient(90deg, rgba(34,197,94,.55), #22c55e); }
  .sb-peak-fill.warn{ background:linear-gradient(90deg, rgba(250,204,21,.5), #facc15); }
  .sb-peak-fill.danger{ background:linear-gradient(90deg, rgba(248,113,113,.5), #f87171); }

  .sb-action-groups{
    display:grid;
    gap:14px;
  }
  .sb-action-group{
    padding:14px;
    border-radius:18px;
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.06);
  }
  .sb-action-group-title{
    margin-bottom:12px;
    color:#cfdcff;
    font-size:.94rem;
    font-weight:800;
    letter-spacing:.02em;
  }
  .sb-action-grid{
    display:grid;
    grid-template-columns:repeat(3, minmax(0, 1fr));
    gap:10px;
  }
  .sb-action-grid.compact{ grid-template-columns:repeat(4, minmax(0, 1fr)); }
  .sb-action-btn{
    min-height:48px;
    display:flex;
    align-items:center;
    gap:10px;
    padding:11px 13px;
    border-radius:14px;
    text-decoration:none;
    color:#e9eefc;
    background:linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.035));
    border:1px solid rgba(255,255,255,.08);
    transition:transform .16s ease, border-color .16s ease, background .16s ease;
  }
  .sb-action-btn:hover{
    transform:translateY(-1px);
    border-color:rgba(96,165,250,.28);
    background:linear-gradient(180deg, rgba(59,130,246,.12), rgba(255,255,255,.04));
  }
  .sb-action-btn.primary{
    background:linear-gradient(180deg, rgba(59,130,246,.24), rgba(59,130,246,.14));
    border-color:rgba(96,165,250,.34);
    color:#f5f8ff;
  }
  .sb-action-btn.wide{ min-height:54px; }

  .sb-side-links{
    display:grid;
    gap:10px;
  }
  .sb-side-link{
    display:flex;
    align-items:flex-start;
    gap:12px;
    padding:14px;
    text-decoration:none;
    color:#e8eefb;
    border-radius:16px;
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.07);
  }
  .sb-side-link small{
    display:block;
    margin-top:4px;
    line-height:1.45;
  }

  .sb-create-form{
    display:grid;
    gap:12px;
  }
  .sb-create-form label{
    display:grid;
    gap:8px;
  }
  .sb-create-form label > span{
    font-size:.92rem;
    color:#d7dff2;
    font-weight:700;
  }
  .sb-form-grid-2{
    display:grid;
    grid-template-columns:repeat(2, minmax(0, 1fr));
    gap:12px;
  }
  .sb-create-form input{
    width:100%;
    min-height:48px;
    padding:0 14px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.1);
    background:rgba(255,255,255,.045);
    color:#edf2ff;
    font:inherit;
    outline:none;
  }
  .sb-create-form input:focus{
    border-color:rgba(96,165,250,.42);
    box-shadow:0 0 0 4px rgba(59,130,246,.12);
  }
  .sb-create-tips{
    display:grid;
    gap:8px;
    margin-top:2px;
  }
  .sb-tip-item{
    display:flex;
    gap:10px;
    align-items:flex-start;
    padding:10px 12px;
    border-radius:14px;
    background:rgba(255,255,255,.035);
    border:1px solid rgba(255,255,255,.06);
    color:#d6dff3;
    line-height:1.55;
  }

  .sb-empty-state{
    display:flex;
    align-items:center;
    gap:16px;
    padding:24px;
    border-radius:20px;
    background:rgba(255,255,255,.04);
    border:1px dashed rgba(255,255,255,.12);
  }
  .sb-empty-icon{
    width:56px;
    height:56px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:rgba(59,130,246,.14);
    border:1px solid rgba(96,165,250,.24);
  }
  .sb-owner-empty{ margin:8px 2px 0; }

  @media (max-width: 1180px){
    .sb-owner-hero,
    .sb-owner-layout{
      grid-template-columns:1fr;
    }
    .sb-owner-side{ position:static; }
    .sb-action-grid.compact{ grid-template-columns:repeat(3, minmax(0, 1fr)); }
