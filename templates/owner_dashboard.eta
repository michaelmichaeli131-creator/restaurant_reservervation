    padding:9px 12px;
    border-radius:999px;
    font-weight:800;
    border:1px solid rgba(255,255,255,.1);
    background:rgba(255,255,255,.04);
  }
  .sb-occupancy-pill.good{ color:#9fe7b2; }
  .sb-occupancy-pill.warn{ color:#ffe184; }
  .sb-occupancy-pill.danger{ color:#ffb4b4; }

  .sb-restaurant-meta{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin-top:14px;
  }
  .sb-restaurant-meta span{
    padding:9px 11px;
    border-radius:12px;
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.06);
    color:#d2dbef;
    font-size:.92rem;
  }

  .sb-restaurant-stats{
    display:grid;
    grid-template-columns:repeat(4, minmax(0, 1fr));
    gap:12px;
    margin:16px 0 12px;
  }
  .sb-mini-stat{
