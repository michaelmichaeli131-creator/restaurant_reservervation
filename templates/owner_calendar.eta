<!doctype html>
<html lang="<%= it.lang %>" dir="<%= it.dir %>">
<head>
  <meta charset="utf-8" />
  <title>
    <% /* tt: תרגום עם fallback אמיתי גם כש-it.t מחזיר "(key)" */ %>
    <% function tt(k, fb){ try{ if (it && typeof it.t==='function'){ const s = it.t(k); if(!s || s===k || s===`(${k})`) return fb; return s; } }catch(e){} return fb; } %>
    <%= (it.title && it.title.trim().length) ? it.title : tt('owner.calendar.head','SpotBook · მფლობელის კალენდარი') %>
  </title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- קובץ הלוגיקה/בסיס קיים שלך -->
  <link rel="stylesheet" href="/static/css/owner_calendar.css" />

  <style>
    /* ===== SpotBook Luxury Dark – Skins only (No feature changes) ===== */
    :root{
      --bg:#0b1120;
      --panel:#111827;
      --panel-2:#0f172a;
      --bd:#1f2937;
      --ink:#e5e7eb;
      --ink-muted:#9aa3b2;

      --brand:#3b82f6;
      --brand-ink:#fff;
      --ok:#10b981;
      --warn:#f59e0b;
      --danger:#ef4444;

      --radius:16px;
      --radius-sm:12px;

      --shadow-lg: 0 20px 60px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.02);
      --shadow-md: 0 10px 26px rgba(0,0,0,.35), inset 0 1px 0 rgba(255,255,255,.02);
    }

    html,body{background:var(--bg);color:var(--ink);font-family:system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif}

    /* Header */
    .oc-header{background:linear-gradient(180deg, rgba(17,24,39,.8), rgba(17,24,39,.35)); border-bottom:1px solid var(--bd)}
    .oc-header .wrap{max-width:1280px;margin:0 auto;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .oc-title{font-weight:800;letter-spacing:.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    /* Lang switch (כפתור 🌐) */
    .lang-switch{ position: relative; display:inline-block; }
    .lang-btn{
      display:inline-flex; align-items:center; justify-content:center;
      width:36px; height:36px; border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      cursor:pointer; box-shadow: inset 0 2px 6px rgba(0,0,0,.25);
      transition: background .15s ease, transform .15s ease;
    }
    .lang-btn:hover { background:rgba(255,255,255,.1); transform:translateY(-1px); }
    .lang-btn::before{ content:"🌐"; font-size:18px; line-height:1; }
    .lang-menu{
      position:absolute; top:110%; inset-inline-end:0;
      background: rgba(15,23,42,.92);
      border:1px solid rgba(255,255,255,.12);
      border-radius:10px; padding:4px;
      box-shadow:0 6px 20px rgba(0,0,0,.35);
      backdrop-filter: blur(10px);
      z-index:60; min-width:140px;
      opacity:0; transform:translateY(-5px) scale(.97);
      pointer-events:none;
      transition:opacity .15s ease, transform .15s ease;
    }
    .lang-menu.open { opacity:1; transform:translateY(0) scale(1); pointer-events:auto; }
    .lang-item{
      display:block; text-align:center; color:#e2e8f0; padding:8px 10px; border-radius:6px;
      text-decoration:none; font-weight:700; font-family:"Rubik",sans-serif;
      transition:background .15s ease; font-size: 14px;
    }
    .lang-item:hover { background:rgba(255,255,255,.08); }
    .lang-item.active { background:rgba(255,255,255,.12); }

    /* Date nav + search */
    .oc-date-nav{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .oc-date-nav .date-label{padding:6px 10px;background:color-mix(in srgb, var(--panel) 86%, transparent); border:1px solid var(--bd); border-radius:10px}
    .oc-date-nav button{appearance:none;border:1px solid var(--bd); background: color-mix(in srgb, var(--panel-2) 92%, transparent); color:var(--ink); border-radius:10px; padding:8px 10px; cursor:pointer; transition:transform .08s ease, filter .12s ease, box-shadow .12s ease}
    .oc-date-nav button:hover{transform:translateY(-1px)}
    .oc-jump{border-color:transparent !important; background:var(--brand) !important; color:#fff !important; box-shadow:0 8px 24px rgba(59,130,246,.28)}

    /* חיפוש יומי */
    .oc-searchbox{
      position: relative; display:flex; align-items:center;
      border:1px solid var(--bd); background:color-mix(in srgb, var(--panel-2) 92%, transparent);
      border-radius:12px; padding-inline:12px; min-height:38px;
      transition: box-shadow .15s ease, border-color .15s ease, background .15s ease;
    }
    .oc-searchbox:hover{ background:color-mix(in srgb, var(--panel) 92%, transparent); }
    .oc-searchbox:focus-within{
      border-color: color-mix(in srgb, var(--brand) 60%, var(--bd));
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 22%, transparent);
      background: #0b1327;
    }
    .oc-searchbox .icon{ width:18px; height:18px; opacity:.7; flex:0 0 auto; margin-inline-end:8px; color:var(--ink-muted) }
    .oc-searchbox input{
      border:0; outline:0; background:transparent; color:var(--ink);
      width:220px; max-width:42vw; font-size:14px; padding:6px 0;
    }
    .oc-searchbox input::placeholder{ color:#94a3b8; }
    @media (max-width:600px){ .oc-searchbox input{ width:160px; } }

    /* ===== Layout: Sidebar + Panel (keeping LTR grid as in original) ===== */
    .oc-main{max-width:1400px;margin:0 auto}
    .oc-layout{
      direction: ltr !important;
      display:grid !important;
      grid-template-columns: minmax(300px, 360px) minmax(0,1fr);
      gap:16px; align-items:start; padding:16px;
    }
    @media (max-width: 900px){
      .oc-layout{ grid-template-columns: 1fr !important; }
    }

    /* Sidebar (Calendar card) */
    .oc-sidebar{
      grid-column:1/2 !important;
      background:var(--panel);
      border:1px solid var(--bd);
      border-radius:var(--radius);
      padding:14px;
      box-shadow:var(--shadow-md);
      color:var(--ink);
    }
    @media (max-width: 900px){
      .oc-sidebar{ grid-column:1/-1 !important; grid-row:2 !important; }
    }
    .oc-section-title{font-weight:800;margin:6px 0 12px; color:var(--ink)}

    /* Mini calendar */
    .mini-cal{user-select:none}
    .mini-cal .hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
    .mini-cal .hdr .nav{display:flex;gap:8px}
    .mini-cal .hdr button{border:1px solid var(--bd);background:color-mix(in srgb, var(--panel-2) 92%, transparent);color:var(--ink);border-radius:10px;padding:6px 10px;cursor:pointer}
    .mini-cal .hdr button:hover{transform:translateY(-1px)}
    .mini-cal .title{color:var(--ink);font-weight:700}
    .mini-cal table{width:100%;border-collapse:collapse}
    .mini-cal th,.mini-cal td{text-align:center;padding:6px 0;width:14.285%}
    .mini-cal th{color:var(--ink-muted);font-weight:700}
    .mini-cal td button{width:34px;height:34px;line-height:34px;border-radius:10px;border:1px solid transparent;background:transparent;color:var(--ink);cursor:pointer;transition:background .12s ease, border-color .12s ease}
    .mini-cal td button:hover{background:color-mix(in srgb, var(--panel) 86%, transparent); border-color:var(--bd)}
    .mini-cal td .out{opacity:.35}
    .mini-cal td .today{outline:2px solid var(--bd); border-radius:10px}
    .mini-cal td .sel{background:var(--brand);color:#fff}

    /* Sidebar daily summary */
    .oc-day-summary{margin-top:14px;font-size:14px;color:var(--ink)}
    .oc-day-summary .bar{height:8px;background:#1f2937;border-radius:999px;overflow:hidden;margin:8px 0}
    .oc-day-summary .bar>div{height:100%;background:var(--warn);width:0%;transition:width .2s}

    .oc-timebox{ margin-top:14px; padding:14px; border-radius:16px; border:1px solid var(--bd); background:color-mix(in srgb, var(--panel-2) 90%, transparent); box-shadow:var(--shadow-sm); }
    .oc-timebox__label{ font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:#93c5fd; font-weight:800; }
    .oc-timebox__current{ margin-top:6px; font-size:20px; font-weight:800; color:var(--ink); }
    .oc-timebox__inputs{ display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:10px; }
    .oc-timebox__inputs input{ width:100%; min-height:40px; border-radius:12px; border:1px solid var(--bd); background:#0b1327; color:var(--ink); padding:0 10px; }
    .oc-timebox__actions{ display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
    .oc-room-graph{ margin-top:14px; padding:14px; border-radius:16px; border:1px solid var(--bd); background:color-mix(in srgb, var(--panel-2) 90%, transparent); }
    .oc-room-graph__title{ display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:12px; }
    .oc-room-graph__title strong{ font-size:15px; }
    .oc-room-graph__title span{ color:var(--ink-muted); font-size:12px; }
    .oc-room-row{ display:grid; grid-template-columns:minmax(90px,140px) 1fr auto; gap:10px; align-items:center; margin-bottom:10px; }
    .oc-room-row__name{ font-weight:700; color:var(--ink); }
    .oc-room-row__bar{ height:12px; background:#1f2937; border-radius:999px; overflow:hidden; position:relative; }
    .oc-room-row__fill{ height:100%; border-radius:999px; transition:width .2s ease; }
    .oc-room-row__meta{ min-width:96px; text-align:end; color:var(--ink-muted); font-size:12px; }

    /* Panel (Slots) */
    .oc-panel{
      grid-column:2/3 !important;
      overflow:hidden;
      background:var(--panel);
      border:1px solid var(--bd);
      border-radius:var(--radius);
      box-shadow:var(--shadow-lg);
      padding:12px;
      width:100% !important;
      max-width:100% !important;
      margin-inline:0 !important;
      justify-self:stretch !important;
    }
    @media (max-width: 900px){
      .oc-panel{ grid-column:1/-1 !important; grid-row:1 !important; }
    }
    .oc-panel-header{ display:flex; align-items:flex-start; justify-content:space-between; gap:12px; padding:4px 4px 12px; }
    .oc-panel-eyebrow{ font-size:11px; text-transform:uppercase; letter-spacing:.16em; color:#93c5fd; font-weight:800; margin-bottom:6px; }
    .oc-cap{ color:var(--ink-muted); font-size:.95rem; margin:0 }
    .oc-panel-badge{ display:inline-flex; align-items:center; gap:8px; padding:10px 12px; border-radius:14px; border:1px solid var(--bd); background:color-mix(in srgb, var(--panel-2) 90%, transparent); color:var(--ink); font-size:13px; font-weight:700; }
    .oc-panel-badge strong{ font-size:18px; }

    .oc-kpis{ display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin:0 4px 16px; }
    .oc-kpi{ padding:14px; border-radius:16px; border:1px solid var(--bd); background:linear-gradient(180deg, rgba(15,23,42,.96), rgba(15,23,42,.72)); box-shadow:var(--shadow-md); min-height:110px; }
    .oc-kpi__label{ font-size:11px; text-transform:uppercase; letter-spacing:.12em; color:var(--ink-muted); font-weight:800; }
    .oc-kpi__value{ margin-top:10px; font-size:28px; line-height:1; font-weight:900; color:#fff; }
    .oc-kpi__sub{ margin-top:10px; color:var(--ink-muted); font-size:13px; }

    .oc-toolbar{ display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; padding:0 4px 14px; }
    .oc-toolbar__legend{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; color:var(--ink-muted); font-size:13px; }
    .oc-toolbar__legend .dot{ width:10px; height:10px; border-radius:999px; display:inline-block; }
    .oc-toolbar__actions{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .oc-filters{ display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .oc-filter{ appearance:none; border:1px solid var(--bd); background:color-mix(in srgb, var(--panel-2) 92%, transparent); color:var(--ink-muted); border-radius:999px; padding:8px 12px; font-size:13px; font-weight:800; cursor:pointer; transition:transform .08s ease, border-color .14s ease, color .14s ease, background .14s ease; }
    .oc-filter:hover{ transform:translateY(-1px); color:var(--ink); }
    .oc-filter.is-active{ border-color:color-mix(in srgb, var(--brand) 55%, var(--bd)); background:color-mix(in srgb, var(--brand) 18%, transparent); color:#dbeafe; box-shadow:0 10px 24px rgba(59,130,246,.16); }

    .oc-slots-wrap{ position:relative; }
    .oc-slots{ min-width:0 !important; }
    .oc-row{ display:grid; grid-template-columns: minmax(88px,108px) minmax(260px,1.45fr) minmax(160px,.9fr) auto; gap:14px; align-items:center; border-bottom:1px solid var(--bd); padding:12px 10px; border-radius:14px; margin-bottom:8px; transition:background .12s ease, border-color .12s ease, transform .12s ease, box-shadow .12s ease; }
    .oc-row:hover{ background: color-mix(in srgb, var(--panel-2) 84%, transparent); border-color: color-mix(in srgb, var(--brand) 28%, var(--bd)); transform:translateY(-1px); box-shadow:0 12px 24px rgba(2,6,23,.24); }
    .oc-row.is-match{ outline:2px solid color-mix(in srgb, var(--brand) 60%, transparent); background:color-mix(in srgb, var(--brand) 12%, transparent); }
    .oc-row.is-dim{ opacity:.5; }
    .oc-th{ background: color-mix(in srgb, var(--panel-2) 88%, transparent); border-radius:12px; font-weight:700; margin-bottom:10px; }
    .oc-time{ display:flex; flex-direction:column; gap:4px; }
    .oc-time__main{ font-size:22px; line-height:1; font-weight:900; color:#fff; }
    .oc-time__sub{ font-size:12px; color:var(--ink-muted); text-transform:uppercase; letter-spacing:.08em; }
    .oc-load{ display:flex; flex-direction:column; gap:10px; min-width:0; }
    .oc-load__top{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .oc-load__title{ font-weight:800; color:#fff; }
    .oc-load__meta{ color:var(--ink-muted); font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .oc-tag{ display:inline-flex; align-items:center; justify-content:center; border-radius:999px; padding:6px 10px; font-size:11px; font-weight:900; letter-spacing:.08em; text-transform:uppercase; border:1px solid transparent; }
    .oc-tag--quiet{ background:rgba(16,185,129,.15); color:#6ee7b7; border-color:rgba(16,185,129,.28); }
    .oc-tag--busy{ background:rgba(245,158,11,.16); color:#fcd34d; border-color:rgba(245,158,11,.32); }
    .oc-tag--full{ background:rgba(239,68,68,.16); color:#fca5a5; border-color:rgba(239,68,68,.32); }
    .oc-info{ color:var(--ink-muted) }
    .oc-availability{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:8px; }
    .oc-stat{ padding:10px; border-radius:12px; border:1px solid rgba(255,255,255,.06); background:rgba(255,255,255,.02); }
    .oc-stat__label{ display:block; font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--ink-muted); font-weight:800; }
    .oc-stat__value{ display:block; margin-top:6px; font-weight:900; color:#fff; }
    .oc-open{ display:inline-flex; align-items:center; gap:8px; border-radius:999px; border:1px solid var(--bd); padding:10px 12px; background:rgba(255,255,255,.02); color:#fff; font-weight:800; white-space:nowrap; }
    .oc-open svg{ width:16px; height:16px; }
    .oc-row[data-current="true"] .oc-open{ border-color:rgba(59,130,246,.45); background:rgba(59,130,246,.12); }

    .oc-empty{ margin:4px; padding:20px; border-radius:16px; border:1px dashed rgba(255,255,255,.14); background:rgba(255,255,255,.02); color:var(--ink-muted); text-align:center; }
    .oc-empty strong{ display:block; margin-bottom:6px; color:#fff; font-size:16px; }
    .oc-hint{ color:var(--ink-muted); font-size:.9rem; margin:12px 4px }
    .oc-summary{ margin:12px 4px 4px; background: color-mix(in srgb, var(--panel-2) 86%, transparent); border:1px solid var(--bd); border-radius:16px; padding:16px }
    .oc-summary-grid{ display:grid; grid-template-columns:repeat(5,minmax(0,1fr)); gap:10px; }
    .oc-summary-card{ padding:12px; border-radius:14px; border:1px solid rgba(255,255,255,.06); background:rgba(255,255,255,.03); }
    .oc-summary-card__label{ font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--ink-muted); font-weight:800; }
    .oc-summary-card__value{ margin-top:10px; font-size:22px; font-weight:900; color:#fff; }
    .oc-summary-card__sub{ margin-top:6px; color:var(--ink-muted); font-size:13px; }

    /* Drawer (Manage customers) */
    .oc-drawer{
      position: fixed; inset-inline-end: 0; top: 0; bottom: 0; width: min(560px, 90vw);
      background: var(--panel-2); color:var(--ink);
      border-inline-start: 1px solid var(--bd);
      transform: translateX(100%); transition: transform .25s ease;
      display:flex; flex-direction:column; z-index: 60; box-shadow: -20px 0 60px rgba(0,0,0,.4);
    }
    .oc-drawer.open{ transform: translateX(0); }
    .oc-drawer header{ display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-bottom:1px solid var(--bd) }
    .oc-drawer .title{ font-weight:800 }
    .oc-drawer .close{
      appearance:none; border:1px solid var(--bd); background:transparent; color:var(--ink);
      border-radius:10px; padding:6px 10px; cursor:pointer;
    }
    .oc-drawer .toolbar{
      padding:10px 16px; display:flex; gap:8px; align-items:center; border-bottom:1px solid var(--bd);
    }
    .oc-drawer .toolbar input[type="search"]{
      flex:1; min-width:0; background:#0b1327; color:var(--ink); border:1px solid var(--bd); border-radius:10px; padding:8px 10px;
      outline:none; transition:border-color .15s ease, box-shadow .15s ease;
    }
    .oc-drawer .toolbar input[type="search"]:focus{
      border-color: color-mix(in srgb, var(--brand) 55%, var(--bd));
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 20%, transparent);
    }
    .oc-drawer .btn{
      appearance:none; border:0; border-radius:12px; padding:10px 12px; font-weight:800; cursor:pointer;
      transition: transform .08s ease, box-shadow .12s ease;
    }
    .oc-drawer .btn.primary{ background:var(--brand); color:#fff; }
    .oc-drawer .btn.primary:hover{ transform: translateY(-1px); box-shadow:0 10px 24px rgba(59,130,246,.28) }

    .oc-drawer .body{ padding:12px 16px; overflow:auto; }
    .tbl{ width:100%; border-collapse: collapse; }
    .tbl th,.tbl td{ border-bottom:1px solid var(--bd); padding:.55rem .5rem; text-align:center }
    .tbl th{ color:var(--ink-muted); font-weight:700 }

    /* “Buttons live” – generic */
    .btn-live{
      display:inline-flex; align-items:center; justify-content:center; gap:8px;
      padding:10px 14px; border-radius:12px; cursor:pointer; text-decoration:none;
      border:1px solid var(--bd); background:transparent; color:var(--ink); font-weight:800;
      transition: transform .08s ease, filter .12s ease, box-shadow .12s ease, background .12s ease;
    }
    .btn-live:hover{ transform: translateY(-1px); }
    .btn-live.primary{ background: var(--brand); color: var(--brand-ink); border-color: transparent; box-shadow: 0 8px 24px rgba(59,130,246,.28) }
    .btn-live.ghost{ background: color-mix(in srgb, var(--panel-2) 90%, transparent) }
    .btn-live.ghost:hover{ background: color-mix(in srgb, var(--panel) 92%, transparent) }
    .btn-live.danger{ background: var(--danger); color:#fff; border-color: transparent }

    /* Override minimal tokens from original light theme to dark without changing structure */
    .muted{ color:var(--ink-muted) }

    /* ===== Deposit Badges ===== */
    .deposit-badge{
      display:inline-flex; align-items:center; gap:6px;
      padding:4px 10px; border-radius:8px; font-size:12px; font-weight:600;
      margin-inline-start:8px;
    }
    .deposit-pending{
      background: color-mix(in srgb, var(--warn) 18%, transparent);
      color: #fbbf24;
      border: 1px solid color-mix(in srgb, var(--warn) 35%, transparent);
    }
    .deposit-paid{
      background: color-mix(in srgb, var(--ok) 18%, transparent);
      color: #4ade80;
      border: 1px solid color-mix(in srgb, var(--ok) 35%, transparent);
    }
    .deposit-refunded{
      background: color-mix(in srgb, #6b7280 18%, transparent);
      color: #9ca3af;
      border: 1px solid color-mix(in srgb, #6b7280 35%, transparent);
    }

    /* Deposit action buttons in drawer */
    .deposit-actions{
      display:flex; gap:8px; margin-top:8px; flex-wrap:wrap;
    }
    .deposit-actions .btn{
      padding:6px 12px; border-radius:10px; font-size:12px; font-weight:700;
      cursor:pointer; border:1px solid var(--bd); transition: transform .08s ease;
    }
    .deposit-actions .btn:hover{ transform:translateY(-1px); }
    .deposit-actions .btn.ok{
      background: var(--ok); color:#fff; border-color:transparent;
    }
    .deposit-actions .btn.warn{
      background: var(--warn); color:#000; border-color:transparent;
    }

    .oc-drawer .body{ padding:0 16px 16px; overflow:auto; }
    .tbl thead th{ position:sticky; top:0; background:var(--panel-2); z-index:1; }
    .tbl td:last-child{ min-width:196px; }

    @media (max-width: 1200px){
      .oc-kpis{ grid-template-columns:repeat(2,minmax(0,1fr)); }
      .oc-summary-grid{ grid-template-columns:repeat(3,minmax(0,1fr)); }
      .oc-row{ grid-template-columns: minmax(82px,96px) minmax(220px,1fr) minmax(150px,.85fr) auto; }
    }
    @media (max-width: 900px){
      .oc-panel-header{ flex-direction:column; align-items:flex-start; }
      .oc-panel-badge{ width:100%; justify-content:space-between; }
      .oc-row, .oc-th{ grid-template-columns: minmax(80px,100px) minmax(0,1fr); }
      .oc-th > :nth-child(3), .oc-th > :nth-child(4){ display:none; }
      .oc-availability, .oc-open{ grid-column:2 / -1; }
      .oc-open{ width:100%; justify-content:center; }
      .oc-kpis{ grid-template-columns:1fr 1fr; }
      .oc-summary-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
    }
    @media (max-width: 640px){
      .oc-layout{ padding:12px; gap:12px; }
      .oc-kpis{ grid-template-columns:1fr; }
      .oc-summary-grid{ grid-template-columns:1fr; }
      .oc-toolbar{ align-items:stretch; }
      .oc-toolbar__actions{ width:100%; justify-content:space-between; }
      .oc-filters{ width:100%; overflow:auto; flex-wrap:nowrap; padding-bottom:2px; }
      .oc-filter{ flex:0 0 auto; }
      .tbl, .tbl thead, .tbl tbody, .tbl tr, .tbl th, .tbl td{ display:block; width:100%; }
      .tbl thead{ display:none; }
      .tbl tr{ border-bottom:1px solid var(--bd); padding:12px 0; }
      .tbl td{ border:0; padding:6px 0; text-align:start; }
      .tbl td::before{ content:attr(data-label); display:block; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-muted); font-weight:800; margin-bottom:4px; }
      .tbl td:last-child{ min-width:0; }
    }

    .oc-side-search{
      margin-top:14px; display:flex; align-items:center; gap:10px; padding:12px 14px;
      border-radius:16px; border:1px solid var(--bd);
      background:linear-gradient(180deg, rgba(15,23,42,.94), rgba(15,23,42,.78));
      box-shadow:var(--shadow-md);
    }
    .oc-side-search__icon{
      width:18px; height:18px; color:#93c5fd; flex:0 0 auto;
    }
    .oc-side-search input{
      width:100%; border:0; outline:0; background:transparent; color:var(--ink);
      font-size:14px; min-width:0;
    }
    .oc-side-search input::placeholder{ color:#94a3b8; }

    .oc-timebox{
      position:relative; overflow:hidden;
      background:
        radial-gradient(circle at top right, rgba(59,130,246,.18), transparent 36%),
        linear-gradient(180deg, rgba(15,23,42,.96), rgba(15,23,42,.8));
      box-shadow:var(--shadow-lg);
    }
    .oc-timebox::after{
      content:""; position:absolute; inset:0; pointer-events:none;
      background:linear-gradient(135deg, rgba(255,255,255,.06), transparent 42%);
      opacity:.7;
    }
    .oc-timebox__label{ position:relative; z-index:1; }
    .oc-timebox__current{ position:relative; z-index:1; font-size:30px; letter-spacing:.02em; }
    .oc-timebox__sub{
      position:relative; z-index:1; margin-top:6px; color:var(--ink-muted); font-size:13px; line-height:1.45;
    }
    .oc-timebox__inputs, .oc-timebox__actions, .oc-timebox__status{ position:relative; z-index:1; }
    .oc-timebox__status{ margin-top:10px; color:var(--ink-muted); font-size:12px; min-height:18px; }

    .oc-service-pulse{
      margin-top:14px; padding:16px; border-radius:18px; border:1px solid var(--bd);
      background:
        radial-gradient(circle at top right, rgba(16,185,129,.1), transparent 36%),
        linear-gradient(180deg, rgba(15,23,42,.96), rgba(15,23,42,.82));
      box-shadow:var(--shadow-lg);
    }
    .oc-service-pulse__eyebrow{
      font-size:11px; text-transform:uppercase; letter-spacing:.16em; color:#93c5fd; font-weight:800;
    }
    .oc-service-pulse__top{
      display:flex; align-items:flex-end; justify-content:space-between; gap:12px; margin-top:10px;
    }
    .oc-service-pulse__score{
      font-size:40px; line-height:1; font-weight:900; color:#fff;
    }
    .oc-service-pulse__mood{
      text-align:end; color:var(--ink-muted); font-size:13px;
    }
    .oc-service-pulse__mood strong{
      display:block; color:#fff; font-size:16px; margin-bottom:4px;
    }
    .oc-service-pulse__meter{
      margin-top:14px; height:10px; background:#111827; border-radius:999px; overflow:hidden; border:1px solid rgba(255,255,255,.05);
    }
    .oc-service-pulse__meter span{
      display:block; height:100%; width:0;
      background:linear-gradient(90deg, rgba(16,185,129,.9), rgba(59,130,246,.95));
      transition:width .2s ease;
    }
    .oc-service-pulse__grid{
      display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; margin-top:14px;
    }
    .oc-service-pulse__mini{
      padding:12px; border-radius:14px; border:1px solid rgba(255,255,255,.06);
      background:rgba(255,255,255,.03);
    }
    .oc-service-pulse__mini span{
      display:block; color:var(--ink-muted); font-size:11px; text-transform:uppercase; letter-spacing:.08em; font-weight:800;
    }
    .oc-service-pulse__mini strong{
      display:block; margin-top:6px; color:#fff; font-size:15px; line-height:1.3;
    }

    .oc-premium-grid{
      display:grid; grid-template-columns:minmax(0,1.2fr) minmax(0,.8fr); gap:12px; padding:0 4px 14px;
    }
    .oc-spotlight-card{
      position:relative; overflow:hidden; min-height:168px;
      padding:18px; border-radius:20px; border:1px solid var(--bd);
      background:
        radial-gradient(circle at top right, rgba(59,130,246,.18), transparent 34%),
        linear-gradient(180deg, rgba(15,23,42,.98), rgba(15,23,42,.82));
      box-shadow:var(--shadow-lg);
    }
    .oc-spotlight-card--alt{
      background:
        radial-gradient(circle at top right, rgba(245,158,11,.12), transparent 34%),
        linear-gradient(180deg, rgba(15,23,42,.98), rgba(15,23,42,.82));
    }
    .oc-spotlight-card::after{
      content:""; position:absolute; inset:0; pointer-events:none;
      background:linear-gradient(135deg, rgba(255,255,255,.06), transparent 44%);
    }
    .oc-spotlight-card > *{ position:relative; z-index:1; }
    .oc-spotlight-card__eyebrow{
      font-size:11px; text-transform:uppercase; letter-spacing:.16em; color:#93c5fd; font-weight:800;
    }
    .oc-spotlight-card__title{
      margin-top:10px; font-size:28px; line-height:1.05; font-weight:900; color:#fff;
      max-width:14ch;
    }
    .oc-spotlight-card__sub{
      margin-top:8px; color:var(--ink-muted); font-size:14px; line-height:1.5; max-width:58ch;
    }
    .oc-spotlight-card__metrics{
      display:flex; flex-wrap:wrap; gap:10px; margin-top:16px;
    }
    .oc-spotlight-pill{
      display:inline-flex; align-items:center; gap:8px; padding:10px 12px; border-radius:999px;
      border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.04); color:#fff; font-weight:800; font-size:13px;
    }
    .oc-spotlight-pill span{ color:var(--ink-muted); font-weight:700; }
    .oc-spotlight-card__grid{
      display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; margin-top:18px;
    }
    .oc-spotlight-mini{
      padding:12px; border-radius:16px; border:1px solid rgba(255,255,255,.06); background:rgba(255,255,255,.03);
    }
    .oc-spotlight-mini span{
      display:block; color:var(--ink-muted); font-size:11px; text-transform:uppercase; letter-spacing:.08em; font-weight:800;
    }
    .oc-spotlight-mini strong{
      display:block; margin-top:6px; color:#fff; font-size:17px; line-height:1.35;
    }
    .oc-spotlight-actions{ display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; }

    .oc-density{
      margin:0 4px 16px; padding:16px; border-radius:18px; border:1px solid var(--bd);
      background:linear-gradient(180deg, rgba(15,23,42,.9), rgba(15,23,42,.72));
      box-shadow:var(--shadow-md);
    }
    .oc-density__header{
      display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:14px;
    }
    .oc-density__header strong{ display:block; font-size:15px; color:#fff; }
    .oc-density__header span{ display:block; color:var(--ink-muted); font-size:12px; margin-top:3px; }
    .oc-density__meta{ color:#cbd5e1; font-size:12px; font-weight:700; }
    .oc-density__rail{
      display:grid; grid-template-columns:repeat(auto-fit,minmax(36px,1fr)); gap:8px; align-items:end;
    }
    .oc-density__slot{
      appearance:none; border:1px solid rgba(255,255,255,.07); background:rgba(255,255,255,.03); color:#fff;
      border-radius:14px; min-height:96px; padding:10px 8px 8px; cursor:pointer;
      display:flex; flex-direction:column; justify-content:flex-end; gap:8px;
      transition:transform .1s ease, border-color .14s ease, background .14s ease, box-shadow .14s ease;
    }
    .oc-density__slot:hover{
      transform:translateY(-2px); border-color:rgba(59,130,246,.34); background:rgba(59,130,246,.08); box-shadow:0 10px 22px rgba(2,6,23,.22);
    }
    .oc-density__slot.is-current{
      border-color:rgba(59,130,246,.46); background:rgba(59,130,246,.12); box-shadow:0 14px 28px rgba(59,130,246,.14);
    }
    .oc-density__slot.is-match{
      box-shadow:0 0 0 2px rgba(59,130,246,.34);
    }
    .oc-density__slot.is-dim{ opacity:.45; }
    .oc-density__bar{
      width:100%; border-radius:999px; min-height:12px; background:#111827; overflow:hidden; position:relative;
    }
    .oc-density__fill{
      position:absolute; inset:0 auto 0 0; width:0; border-radius:999px;
      transition:width .18s ease;
    }
    .oc-density__time{ font-size:12px; font-weight:900; line-height:1; }
    .oc-density__pct{ font-size:11px; color:var(--ink-muted); }

    .oc-band-grid{
      display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:10px; padding:0 4px 16px;
    }
    .oc-band-card{
      appearance:none; border:1px solid var(--bd); background:rgba(255,255,255,.02); color:#fff; cursor:pointer;
      border-radius:16px; padding:14px; text-align:start; transition:transform .08s ease, border-color .14s ease, background .14s ease, box-shadow .14s ease;
    }
    .oc-band-card:hover{ transform:translateY(-1px); border-color:rgba(59,130,246,.28); background:rgba(59,130,246,.06); box-shadow:0 12px 24px rgba(2,6,23,.18); }
    .oc-band-card.is-active{ border-color:rgba(59,130,246,.48); background:rgba(59,130,246,.12); box-shadow:0 16px 28px rgba(59,130,246,.12); }
    .oc-band-card__label{ display:block; color:var(--ink-muted); font-size:11px; letter-spacing:.1em; text-transform:uppercase; font-weight:800; }
    .oc-band-card__value{ display:block; margin-top:10px; font-size:26px; font-weight:900; line-height:1; }
    .oc-band-card__sub{ display:block; margin-top:8px; color:var(--ink-muted); font-size:13px; }

    @media (max-width: 1200px){
      .oc-premium-grid{ grid-template-columns:1fr; }
    }
    @media (max-width: 900px){
      .oc-service-pulse__grid, .oc-spotlight-card__grid{ grid-template-columns:1fr 1fr; }
      .oc-band-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
    }
    @media (max-width: 640px){
      .oc-service-pulse__top{ flex-direction:column; align-items:flex-start; }
      .oc-service-pulse__mood{ text-align:start; }
      .oc-service-pulse__grid, .oc-spotlight-card__grid, .oc-band-grid{ grid-template-columns:1fr; }
      .oc-density__rail{ grid-template-columns:repeat(auto-fit,minmax(52px,1fr)); }
    }

  </style>
  <link rel="stylesheet" href="/public/css/sb-tablet-support.css?v=<%= it.BUILD_TAG || Date.now() %>" />
</head>
<body>
  <!-- Header -->
  <div class="oc-header">
    <div class="wrap">
      <div class="oc-title">
        <%= (it.restaurant && it.restaurant.name) ? it.restaurant.name : tt('owner.calendar.title','יומן בעלים') %>
      </div>

      <!-- מתג שפה (כדור הארץ) -->
      <div class="lang-switch">
        <button class="lang-btn" id="langBtn" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="langMenu" title="<%= tt('nav.language','בחר שפה') %>"></button>
        <div class="lang-menu" id="langMenu" role="menu">
          <a class="lang-item <%= (it.lang==='en')?'active':'' %>" href="#" data-lang="en" role="menuitem">EN</a>
          <a class="lang-item <%= (it.lang==='ka')?'active':'' %>" href="#" data-lang="ka" role="menuitem">GE</a>
          <a class="lang-item <%= (!it.lang || it.lang==='he')?'active':'' %>" href="#" data-lang="he" role="menuitem">HE</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary row: date & search -->
  <div class="oc-header">
    <div class="wrap">
      <div class="oc-date-nav">
        <button id="btn-prev" aria-label="<%= tt('owner.calendar.prev_day_aria','יום קודם') %>" class="btn-live ghost">◀</button>
        <div class="date-label" id="date-label">—</div>
        <button id="btn-next" aria-label="<%= tt('owner.calendar.next_day_aria','יום הבא') %>" class="btn-live ghost">▶</button>
        <button id="btn-jump" aria-label="<%= tt('owner.calendar.jump_to_date_aria','קפיצה לתאריך') %>" class="btn-live primary oc-jump">📅 <%= tt('owner.calendar.pick_date','בחר תאריך') %></button>
        <input type="date" id="datePicker" style="display:none" value="<%= it.date %>"/>

        <!-- שדה חיפוש מעוצב ליד התאריך -->
        <label class="oc-searchbox" for="daySearch" aria-label="<%= tt('owner.calendar.search_day_aria','חיפוש ביום הנוכחי') %>">
          <span class="icon" aria-hidden="true">
            <!-- SVG זכוכית מגדלת -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </span>
          <input type="search" id="daySearch" placeholder="<%= tt('owner.calendar.search_placeholder','חפש שם') %>"/>
        </label>
      </div>
    </div>
  </div>

  <!-- Layout -->
  <main class="oc-main">
    <div class="oc-layout">
      <!-- Sidebar (שמאל בפועל) -->
      <aside class="oc-sidebar" id="sidebar">
        <div class="oc-section-title"><%= tt('owner.calendar.sidebar.calendar','לוח שנה') %></div>
        <div class="mini-cal" id="mini-cal">
          <div class="hdr">
            <div class="nav">
              <button id="cal-prev" aria-label="<%= tt('owner.calendar.prev_month','חודש קודם') %>">‹</button>
              <button id="cal-next" aria-label="<%= tt('owner.calendar.next_month','חודש הבא') %>">›</button>
            </div>
            <div class="title" id="cal-title">—</div>
          </div>
          <table>
            <thead><tr id="cal-weekdays"></tr></thead>
            <tbody id="cal-body"></tbody>
          </table>
        </div>

        <div class="oc-section-title" style="margin-top:16px"><%= tt('owner.calendar.sidebar.daily_summary','סיכום יומי') %></div>
        <div class="oc-day-summary" id="day-summary-box">
          <div id="day-summary-text"><%= tt('owner.calendar.loading','טוען…') %></div>
          <div class="bar"><div id="day-summary-bar"></div></div>
        </div>

        <div class="oc-side-search">
          <svg class="oc-side-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="search" id="sideSearch" placeholder="<%= tt('owner.calendar.search_focus_placeholder','Quick focus search') %>" />
        </div>

        <div class="oc-timebox" id="oc-timebox">
          <div class="oc-timebox__label"><%= tt('owner.calendar.clock.label','Restaurant Clock') %></div>
          <div class="oc-timebox__current" id="oc-system-time-preview"><%= it.systemNowTime || '12:00' %></div>
          <div class="oc-timebox__sub"><%= tt('owner.calendar.clock.subtitle','Preview the service flow at any date and time without leaving the calendar.') %></div>
          <div class="oc-timebox__inputs">
            <input type="date" id="oc-system-date" value="<%= it.systemNowDate || it.date %>">
            <input type="time" id="oc-system-time" value="<%= it.systemNowTime || '12:00' %>">
          </div>
          <div class="oc-timebox__actions">
            <button class="btn-live primary" id="oc-system-apply-btn" type="button"><%= tt('owner.calendar.clock.apply','Apply preview') %></button>
            <button class="btn-live ghost" id="oc-system-now-btn" type="button"><%= tt('owner.calendar.clock.now','Use real time') %></button>
          </div>
          <div class="oc-timebox__status" id="oc-system-time-status"><%= tt('owner.calendar.clock.ready','Live view ready') %></div>
        </div>

        <div class="oc-service-pulse" id="oc-service-pulse">
          <div class="oc-service-pulse__eyebrow"><%= tt('owner.calendar.service_pulse','Service Pulse') %></div>
          <div class="oc-service-pulse__top">
            <div class="oc-service-pulse__score" id="oc-service-score">—</div>
            <div class="oc-service-pulse__mood">
              <strong id="oc-service-mood">—</strong>
              <span id="oc-service-mood-sub"><%= tt('owner.calendar.loading','טוען…') %></span>
            </div>
          </div>
          <div class="oc-service-pulse__meter"><span id="oc-service-score-bar"></span></div>
          <div class="oc-service-pulse__grid">
            <div class="oc-service-pulse__mini">
              <span><%= tt('owner.calendar.service_pulse.next_peak','Next peak') %></span>
              <strong id="oc-next-peak">—</strong>
            </div>
            <div class="oc-service-pulse__mini">
              <span><%= tt('owner.calendar.service_pulse.window','Service window') %></span>
              <strong id="oc-service-window">—</strong>
            </div>
            <div class="oc-service-pulse__mini">
              <span><%= tt('owner.calendar.service_pulse.peak_room','Peak room') %></span>
              <strong id="oc-peak-room">—</strong>
            </div>
            <div class="oc-service-pulse__mini">
              <span><%= tt('owner.calendar.service_pulse.focus','Visible focus') %></span>
              <strong id="oc-visible-focus">—</strong>
            </div>
          </div>
        </div>

        <div class="oc-room-graph" id="oc-room-graph">
          <div class="oc-room-graph__title">
            <strong><%= tt('owner.calendar.room_graph.title','Room Occupancy Right Now') %></strong>
            <span id="oc-room-graph-time"><%= it.systemNowTime || '12:00' %></span>
          </div>
          <div id="oc-room-graph-body"><div class="muted"><%= tt('owner.calendar.loading','טוען…') %></div></div>
        </div>
      </aside>

      <!-- Panel (ימין בפועל) -->
      <section class="oc-panel">
        <header class="oc-panel-header">
          <div>
            <div class="oc-panel-eyebrow"><%= tt('owner.calendar.panel.eyebrow','Service Flow') %></div>
            <div class="oc-cap" id="cap-line">
              <%= tt('owner.calendar.cap_line','קיבולת: סועדים — • שולחנות — • צעד: —') %>
            </div>
          </div>
          <div class="oc-panel-badge" id="oc-current-badge">
            <span><%= tt('owner.calendar.current_badge','Current service time') %></span>
            <strong id="oc-current-time-chip"><%= it.systemNowTime || '12:00' %></strong>
          </div>
        </header>

        <section class="oc-kpis" id="oc-kpis" aria-label="<%= tt('owner.calendar.kpis','Daily insights') %>">
          <article class="oc-kpi">
            <div class="oc-kpi__label"><%= tt('owner.calendar.summary.total_reservations','Total Reservations') %></div>
            <div class="oc-kpi__value">—</div>
            <div class="oc-kpi__sub"><%= tt('owner.calendar.loading','טוען…') %></div>
          </article>
          <article class="oc-kpi">
            <div class="oc-kpi__label"><%= tt('owner.calendar.summary.total_guests','Total Guests') %></div>
            <div class="oc-kpi__value">—</div>
            <div class="oc-kpi__sub"><%= tt('owner.calendar.loading','טוען…') %></div>
          </article>
          <article class="oc-kpi">
            <div class="oc-kpi__label"><%= tt('owner.calendar.summary.peak','Peak') %></div>
            <div class="oc-kpi__value">—</div>
            <div class="oc-kpi__sub"><%= tt('owner.calendar.loading','טוען…') %></div>
          </article>
          <article class="oc-kpi">
            <div class="oc-kpi__label"><%= tt('owner.calendar.summary.avg_occupancy','Avg Occupancy') %></div>
            <div class="oc-kpi__value">—</div>
            <div class="oc-kpi__sub"><%= tt('owner.calendar.loading','טוען…') %></div>
          </article>
        </section>

        <div class="oc-toolbar">
          <div class="oc-toolbar__legend">
            <span><span class="dot" style="background:var(--ok)"></span> <%= tt('owner.calendar.legend.quiet','Comfortable') %></span>
            <span><span class="dot" style="background:var(--warn)"></span> <%= tt('owner.calendar.legend.busy','Busy') %></span>
            <span><span class="dot" style="background:var(--danger)"></span> <%= tt('owner.calendar.legend.full','Nearly full') %></span>
          </div>
          <div class="oc-toolbar__actions">
            <div class="oc-filters" id="oc-filters" aria-label="<%= tt('owner.calendar.filters.aria','Occupancy filters') %>">
              <button class="oc-filter is-active" data-filter="all" type="button"><%= tt('owner.calendar.filters.all','All slots') %></button>
              <button class="oc-filter" data-filter="quiet" type="button"><%= tt('owner.calendar.filters.quiet','Quiet') %></button>
              <button class="oc-filter" data-filter="busy" type="button"><%= tt('owner.calendar.filters.busy','Busy') %></button>
              <button class="oc-filter" data-filter="full" type="button"><%= tt('owner.calendar.filters.full','Critical') %></button>
            </div>
            <button class="btn-live ghost" id="btn-jump-now" type="button">⏱ <%= tt('owner.calendar.jump_now','Jump to now') %></button>
          </div>
        </div>

        <section class="oc-premium-grid">
          <article class="oc-spotlight-card" id="oc-service-spotlight">
            <div class="oc-spotlight-card__eyebrow"><%= tt('owner.calendar.spotlight.eyebrow','Luxury service overview') %></div>
            <div class="oc-spotlight-card__title" id="oc-spotlight-title"><%= tt('owner.calendar.loading','טוען…') %></div>
            <div class="oc-spotlight-card__sub" id="oc-spotlight-sub"><%= tt('owner.calendar.loading','טוען…') %></div>
            <div class="oc-spotlight-card__metrics" id="oc-spotlight-metrics"></div>
            <div class="oc-spotlight-actions">
              <button class="btn-live primary" id="oc-open-next-peak" type="button"><%= tt('owner.calendar.spotlight.next_peak_cta','Go to next peak') %></button>
              <button class="btn-live ghost" id="oc-open-current-slot" type="button"><%= tt('owner.calendar.spotlight.current_cta','Open current slot') %></button>
            </div>
          </article>
          <article class="oc-spotlight-card oc-spotlight-card--alt">
            <div class="oc-spotlight-card__eyebrow"><%= tt('owner.calendar.spotlight.detail_eyebrow','Operational details') %></div>
            <div class="oc-spotlight-card__grid">
              <div class="oc-spotlight-mini">
                <span><%= tt('owner.calendar.spotlight.current_load','Current load') %></span>
                <strong id="oc-current-load">—</strong>
              </div>
              <div class="oc-spotlight-mini">
                <span><%= tt('owner.calendar.spotlight.current_room','Top room now') %></span>
                <strong id="oc-current-room">—</strong>
              </div>
              <div class="oc-spotlight-mini">
                <span><%= tt('owner.calendar.spotlight.expected_guests','Expected guests') %></span>
                <strong id="oc-expected-guests">—</strong>
              </div>
              <div class="oc-spotlight-mini">
                <span><%= tt('owner.calendar.spotlight.alerts','Recovery watch') %></span>
                <strong id="oc-recovery-watch">—</strong>
              </div>
            </div>
          </article>
        </section>

        <section class="oc-density" id="oc-density">
          <div class="oc-density__header">
            <div>
              <strong><%= tt('owner.calendar.density.title','Timeline density') %></strong>
              <span><%= tt('owner.calendar.density.subtitle','Tap a pulse to jump straight to the slot') %></span>
            </div>
            <div class="oc-density__meta" id="oc-density-meta"><%= tt('owner.calendar.loading','טוען…') %></div>
          </div>
          <div class="oc-density__rail" id="oc-density-rail"></div>
        </section>

        <section class="oc-band-grid" id="oc-band-grid" aria-label="<%= tt('owner.calendar.band_cards','Slot mix') %>"></section>

        <div class="oc-slots-wrap">
          <div class="oc-slots" id="slots">
            <div class="oc-row oc-th">
              <div><%= tt('owner.calendar.th.time','שעה') %></div>
              <div><%= tt('owner.calendar.th.occupancy','תפוסה') %></div>
              <div class="oc-info"><%= tt('owner.calendar.th.people_tables_pct','Availability') %></div>
              <div class="oc-info"><%= tt('owner.calendar.actions.open','Open') %></div>
            </div>
            <!-- rows injected by JS -->
          </div>
          <div class="oc-empty" id="oc-empty-state" hidden>
            <strong><%= tt('owner.calendar.empty.title','No slots match this view') %></strong>
            <span id="oc-empty-copy"><%= tt('owner.calendar.empty.subtitle','Try a different filter or search for another guest.') %></span>
          </div>
        </div>

        <div class="oc-hint" id="oc-hint"><%= tt('owner.calendar.hint','רמז: לחץ על סלוט כדי לנהל לקוחות') %></div>

        <div class="oc-summary" id="summary">
          <%= tt('owner.calendar.daily_summary_loading','סיכום יומי — נטען…') %>
        </div>
      </section>
    </div>
  </main>

  <!-- Drawer -->
  <aside class="oc-drawer" id="drawer">
    <header>
      <div class="title" id="drawer-title"><%= tt('owner.calendar.drawer.title','לקוחות') %></div>
      <button class="close" id="drawer-close" aria-label="<%= tt('owner.calendar.drawer.close','סגור') %>">✕</button>
    </header>
    <div class="toolbar">
      <input type="search" id="drawer-search" placeholder="<%= tt('owner.calendar.drawer.search_placeholder','חפש שם בסלוט זה') %>"/>
      <button class="btn primary" id="btn-add">＋ <%= tt('owner.calendar.drawer.add_customer','הוסף לקוח') %></button>
    </div>
    <div class="body">
      <table class="tbl" id="drawer-table">
        <thead>
          <tr>
            <th><%= tt('owner.calendar.tbl.first_name','שם פרטי') %></th>
            <th><%= tt('owner.calendar.tbl.last_name','שם משפחה') %></th>
            <th><%= tt('owner.calendar.tbl.party_size','גודל קבוצה') %></th>
            <th><%= tt('owner.calendar.tbl.room','חדר') %></th>
            <th><%= tt('owner.calendar.tbl.status','סטטוס') %></th>
            <th><%= tt('owner.calendar.tbl.phone','טלפון') %></th>
            <th></th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </aside>

  <!-- קובץ הסקריפט הקיים שלך נשאר ללא שינוי -->
  <script src="/static/js/owner_calendar.js" defer></script>
  <script>
    window.__OC__ = {
      rid: "<%= it.rid %>",
      date: "<%= it.date %>",
      lang: "<%= it.lang || 'en' %>",
      locale: "<%= it.lang === 'ka' ? 'ka-GE' : (it.lang === 'he' ? 'he-IL' : 'en-US') %>",
      systemNowDate: "<%= it.systemNowDate || it.date %>",
      systemNowTime: "<%= it.systemNowTime || '12:00' %>",
      txt: {
        noRoomData: "<%= tt('owner.calendar.room_graph.empty','No room data') %>",
        pickBoth: "<%= tt('host.system_time.pick_both','Please choose both date and time.') %>",
        usingRealTime: "<%= tt('owner.calendar.system_time.using_realtime','Using real time now.') %>",
        syncedAll: "<%= tt('owner.calendar.system_time.synced','Restaurant time updated for all connected systems.') %>",
        leftSuffix: "<%= tt('owner.calendar.room_graph.left_suffix','left') %>",
        time: "<%= tt('owner.calendar.th.time','Time') %>",
        occupancy: "<%= tt('owner.calendar.th.occupancy','Occupancy') %>",
        peopleTablesPct: "<%= tt('owner.calendar.th.people_tables_pct','People • Tables • %') %>",
        capacityPeople: "<%= tt('owner.calendar.capacity_people','People') %>",
        capacityTables: "<%= tt('owner.calendar.capacity_tables','Tables') %>",
        capacityStep: "<%= tt('owner.calendar.capacity_step','Step') %>",
        minutesShort: "<%= tt('owner.calendar.minutes_short','m') %>",
        people: "<%= tt('owner.calendar.people','People') %>",
        tables: "<%= tt('owner.calendar.tables','Tables') %>",
        totalReservations: "<%= tt('owner.calendar.summary.total_reservations','Total Reservations') %>",
        totalGuests: "<%= tt('owner.calendar.summary.total_guests','Total Guests') %>",
        avgOccupancy: "<%= tt('owner.calendar.summary.avg_occupancy','Avg Occupancy') %>",
        peak: "<%= tt('owner.calendar.summary.peak','Peak') %>",
        cancelled: "<%= tt('owner.calendar.summary.cancelled','Cancelled') %>",
        noShow: "<%= tt('owner.calendar.summary.no_show','No-Show') %>",
        dailySummaryLoading: "<%= tt('owner.calendar.daily_summary_loading','Daily summary — loading…') %>",
        customersAt: "<%= tt('owner.calendar.drawer.customers_at','Customers') %>",
        promptFirstName: "<%= tt('owner.calendar.drawer.prompt_first_name','First name:') %>",
        promptLastName: "<%= tt('owner.calendar.drawer.prompt_last_name','Last name:') %>",
        promptPhone: "<%= tt('owner.calendar.drawer.prompt_phone','Phone (optional):') %>",
        promptPartySize: "<%= tt('owner.calendar.drawer.prompt_party_size','Party size:') %>",
        promptNotes: "<%= tt('owner.calendar.drawer.prompt_notes','Notes (optional):') %>",
        btnArrived: "<%= tt('owner.calendar.actions.arrived','Arrived') %>",
        btnCancel: "<%= tt('owner.calendar.actions.cancel','Cancel') %>",
        btnConfirmDeposit: "<%= tt('owner.calendar.actions.confirm_deposit','Confirm deposit') %>",
        btnRefundDeposit: "<%= tt('owner.calendar.actions.refund_deposit','Refund') %>",
        statusNew: "<%= tt('owner.calendar.status.new','New') %>",
        statusPending: "<%= tt('owner.calendar.status.pending','Pending') %>",
        statusBooked: "<%= tt('owner.calendar.status.booked','Booked') %>",
        statusApproved: "<%= tt('owner.calendar.status.approved','Approved') %>",
        statusConfirmed: "<%= tt('owner.calendar.status.confirmed','Confirmed') %>",
        statusArrived: "<%= tt('owner.calendar.status.arrived','Arrived') %>",
        statusCancelled: "<%= tt('owner.calendar.status.cancelled','Cancelled') %>",
        depositPending: "<%= tt('owner.calendar.deposit.pending','Deposit Pending') %>",
        depositReceived: "<%= tt('owner.calendar.deposit.received','Deposit Paid') %>",
        depositRefunded: "<%= tt('owner.calendar.deposit.refunded','Refunded') %>",
        servicePulseLabel: "<%= tt('owner.calendar.service_pulse','Service Pulse') %>",
        serviceFlowBalanced: "<%= tt('owner.calendar.service_flow.balanced','Balanced flow') %>",
        serviceFlowBusy: "<%= tt('owner.calendar.service_flow.busy','Rush building up') %>",
        serviceFlowCritical: "<%= tt('owner.calendar.service_flow.critical','Critical pressure') %>",
        serviceFlowCalm: "<%= tt('owner.calendar.service_flow.calm','Calm service') %>",
        serviceWindowLabel: "<%= tt('owner.calendar.service_pulse.window','Service window') %>",
        nextPeakLabel: "<%= tt('owner.calendar.service_pulse.next_peak','Next peak') %>",
        peakRoomLabel: "<%= tt('owner.calendar.service_pulse.peak_room','Peak room') %>",
        visibleFocusLabel: "<%= tt('owner.calendar.service_pulse.focus','Visible focus') %>",
        densityJumpHint: "<%= tt('owner.calendar.density.subtitle','Tap a pulse to jump straight to the slot') %>",
        visibleSlotsMeta: "<%= tt('owner.calendar.visible_slots_meta','Visible slots') %>",
        currentLoadLabel: "<%= tt('owner.calendar.spotlight.current_load','Current load') %>",
        currentRoomLabel: "<%= tt('owner.calendar.spotlight.current_room','Top room now') %>",
        expectedGuestsLabel: "<%= tt('owner.calendar.spotlight.expected_guests','Expected guests') %>",
        recoveryWatchLabel: "<%= tt('owner.calendar.spotlight.alerts','Recovery watch') %>",
        guestsLeftLabel: "<%= tt('owner.calendar.left_guests','Guests left') %>",
        topRoomNowSub: "<%= tt('owner.calendar.room_graph.title','Room Occupancy Right Now') %>",
        nextPeakCta: "<%= tt('owner.calendar.spotlight.next_peak_cta','Go to next peak') %>",
        openCurrentCta: "<%= tt('owner.calendar.spotlight.current_cta','Open current slot') %>",
        viewSlotCta: "<%= tt('owner.calendar.open_slot','Open slot') %>",
        allSlotsLabel: "<%= tt('owner.calendar.filters.all','All slots') %>",
        quietLabel: "<%= tt('owner.calendar.filters.quiet','Quiet') %>",
        busyLabel: "<%= tt('owner.calendar.filters.busy','Busy') %>",
        fullLabel: "<%= tt('owner.calendar.filters.full','Critical') %>",
        slotsLabel: "<%= tt('owner.calendar.slots_label','slots') %>",
        matchingGuestsLabel: "<%= tt('owner.calendar.matching_guests','matching guests') %>",
        occupancyScoreLabel: "<%= tt('owner.calendar.occupancy_score','Service score') %>"
      }
    };

    // "בחר תאריך" עליון
    (function () {
      const btnJump = document.getElementById('btn-jump');
      const picker = document.getElementById('datePicker');
      if (btnJump && picker) {
        btnJump.addEventListener('click', () => picker.showPicker ? picker.showPicker() : picker.click());
        picker.addEventListener('change', () => {
          const v = picker.value; if (!v) return;
          const url = new URL(window.location.href);
          url.searchParams.set('date', v);
          window.location.href = url.toString();
        });
      }
    })();

    // Toggle לתפריט שפה + בניית קישורי /lang/<code>?redirect=<current>
    (function(){
      const btn  = document.getElementById('langBtn');
      const menu = document.getElementById('langMenu');
      if(!btn || !menu) return;

      function openM(){ menu.classList.add('open');  btn.setAttribute('aria-expanded','true'); }
      function closeM(){ menu.classList.remove('open'); btn.setAttribute('aria-expanded','false'); }
      function toggleM(e){ e?.stopPropagation(); menu.classList.contains('open') ? closeM() : openM(); }

      btn.addEventListener('click', toggleM);
      document.addEventListener('click', (e)=>{ if(!menu.contains(e.target) && e.target!==btn) closeM(); });
      document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') closeM(); });

      // בונים href-ים בזמן ריצה
      const cur = location.pathname + location.search;
      for (const a of menu.querySelectorAll('.lang-item')) {
        const code = a.getAttribute('data-lang');
        if (!code) continue;
        a.setAttribute('href', `/lang/${code}?redirect=${encodeURIComponent(cur)}`);
      }
    })();
  </script>
</body>
</html>
