    width:18px;height:18px;flex:0 0 18px;display:inline-flex;align-items:center;justify-content:center;
    font-size:16px;line-height:1;
  }
  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:11px 14px; border-radius:14px; cursor:pointer; text-decoration:none;
    border:1px solid rgba(123,147,205,.18);
    background:rgba(255,255,255,.04);
    color:var(--ink, #e6e8ef); font-weight:800;
    transition: transform .12s ease, filter .12s ease, box-shadow .12s ease, border-color .12s ease;
    box-shadow:0 10px 24px rgba(0,0,0,.14);
  }
  .btn:hover{ transform: translateY(-1px); border-color:rgba(123,147,205,.34); }
  .btn.primary{
    background:linear-gradient(135deg, var(--brand, #3b82f6), #60a5fa);
    color:var(--brand-ink, #fff);
    border-color:transparent;
    box-shadow:0 16px 34px rgba(59,130,246,.34);
  }
  .btn.ghost{ background:rgba(255,255,255,.045); }
  .btn.ghost:hover{ background:rgba(255,255,255,.07); }
  .btn.sm{ padding:9px 13px; border-radius:12px; }

  .actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
  .owner-primary-actions,
  .owner-pos-actions{align-items:stretch}
  .owner-primary-actions .btn,
  .owner-pos-actions .btn{
    min-height:46px;
    background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.035));
  }
  .owner-pos-actions .btn.wide{
    min-width:180px;
    flex:1 1 180px;
  }

  .form label{ display:flex; flex-direction:column; gap:7px; font-weight:700; font-size:14px; margin-top:8px }
  .form input{
    width:100%;padding:12px 14px;margin-top:0;
    background:rgba(9,15,29,.94);color:#e6e8ef;border:1px solid rgba(123,147,205,.16);border-radius:16px;
    font-size:14px; outline:none; transition: box-shadow .15s ease, border-color .15s ease;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
  }
  .form input:focus{
    border-color: color-mix(in srgb, var(--brand, #3b82f6) 60%, #23293a);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand, #3b82f6) 20%, transparent);
  }

  .sep{height:1px;background:rgba(255,255,255,.08);margin:14px 0;border-radius:999px}

  .owner-create-card .btn.primary{
